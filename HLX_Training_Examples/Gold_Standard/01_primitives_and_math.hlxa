// HLX Training Example: 01_Primitives_and_Math
// CONCEPT: Mixed-Mode Arithmetic & Deterministic Floats
//
// EXPLANATION:
// HLX supports integers (64-bit signed) and floats (64-bit IEEE 754).
// Determinism is guaranteed even for floating point operations.
// The compiler automatically handles promotion of Int to Float in mixed operations.
//
// LLM OBJECTIVE:
// Learn that 'x / y' where both are Ints performs integer division.
// Learn that 'x / y' where one is Float results in a Float.

program math_basics {
    fn main() {
        // --- Integer Arithmetic ---
        let a = 10;
        let b = 3;
        
        // Integer division truncates towards zero
        // Expected: 3
        print("Integer Division (10 / 3):");
        print(a / b); 

        // --- Mixed Arithmetic ---
        let c = 2.5;

        // 'a' (10) is promoted to 10.0 automatically
        // Expected: 25.0
        print("Mixed Multiplication (10 * 2.5):");
        print(a * c);

        // --- Floating Point Precision ---
        // HLX guarantees standard IEEE 754 behavior
        let x = 0.1;
        let y = 0.2;
        
        print("Float Addition (0.1 + 0.2):");
        print(x + y);
        
        // --- Order of Operations ---
        // Standard PEMDAS applies
        // (10 + 2) * 3 = 36
        // 10 + 2 * 3 = 16
        print("Precedence ((10 + 2) * 3):");
        print((a + 2) * b);
        
        print("Precedence (10 + 2 * 3):");
        print(a + 2 * b);

        return 0;
    }
}
