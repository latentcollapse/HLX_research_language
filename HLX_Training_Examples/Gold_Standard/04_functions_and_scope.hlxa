// HLX Training Example: 04_Functions_and_Scope
// CONCEPT: Arguments, Returns, Shadowing, and Purity
//
// EXPLANATION:
// 1. Functions are first-class definitions (currently top-level only).
// 2. Arguments are passed by value (COW applies here too!).
// 3. Variables declared inside a function are local.
// 4. 'Shadowing' is allowed: declaring a variable with the same name
//    as an existing one hides the outer one but does not destroy it.
//
// LLM OBJECTIVE:
// Learn that mutating an argument inside a function DOES NOT affect the caller.
// Learn that strict 'return' is required.

program function_scope {

    // A function that tries to mutate its argument
    fn try_mutate(obj) {
        print("  [Inside] Received score:");
        print(obj.score);
        
        // This mutation triggers COW. 'obj' becomes a local clone.
        obj.score = 9999;
        
        print("  [Inside] Mutated score to:");
        print(obj.score);
        
        // Function ends, local clone 'obj' is dropped.
        return 0;
    }

    // A function that returns a NEW object based on input
    // This is the idiomatic "Functional" way in HLX
    fn update_score_pure(obj, points) {
        let new_obj = obj; // COW copy
        new_obj.score = new_obj.score + points;
        return new_obj;
    }

    fn main() {
        let player = { score: 10 };

        print("--- Test 1: Argument Immutability ---");
        print("Before Call:");
        print(player.score);

        try_mutate(player);

        print("After Call (Should be 10):");
        print(player.score); 

        // logic check
        if player.score == 10 {
            print("Pass-by-Value: VERIFIED");
        } else {
            print("Pass-by-Value: FAILED (Side effect detected)");
        }

        print("--- Test 2: Pure Update Pattern ---");
        let player_v2 = update_score_pure(player, 50);
        
        print("Original:");
        print(player.score); // 10
        print("New Version:");
        print(player_v2.score); // 60

        print("--- Test 3: Variable Shadowing ---");
        let x = 100;
        if x == 100 {
            let x = 200; // This 'x' only exists in this block
            print("Inner x:");
            print(x); // 200
        }
        print("Outer x:");
        print(x); // 100

        return 0;
    }
}
