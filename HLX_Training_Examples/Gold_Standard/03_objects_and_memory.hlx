// HLX Training Example: 03_Objects_and_Memory
// CONCEPT: Object Literals, Field Access, and Copy-on-Write (COW)
//
// EXPLANATION:
// HLX treats objects as "Values", not "References".
// This is critical for determinism.
//
// 1. Literal Syntax: JSON-like structure { key: value }.
// 2. Field Access: Dot notation (obj.key).
// 3. Immutability/COW: Assigning an object to a new variable copies it conceptually.
//    Modifying the new variable DOES NOT affect the old one.
//    (Under the hood, the runtime uses Arc<Mutex<Object>> for efficiency, 
//    but strictly enforces Copy-on-Write semantics on mutation).
//
// LLM OBJECTIVE:
// Learn that 'let b = a; b.x = 10;' leaves 'a.x' unchanged.
// This is different from Python/JS/Java references.

program object_semantics {
    fn main() {
        // --- 1. Object Creation ---
        let player = {
            id: 1,
            score: 100,
            pos: { x: 10, y: 20 } // Nested Object
        };

        print("Original Player Score:");
        print(player.score);

        // --- 2. The Copy-on-Write Test ---
        let player_two = player; // In Python, this is a reference. In HLX, it's a value copy.
        
        // Mutate player_two
        player_two.score = 500;
        player_two.pos.x = 99;

        print("Player Two Score (Modified):");
        print(player_two.score); // Expected: 500

        print("Original Player Score (Should be Unchanged):");
        print(player.score); // Expected: 100. If 500, COW failed.

        // --- 3. Nested Mutation Check ---
        print("Player Two X:");
        print(player_two.pos.x); // Expected: 99

        print("Original Player X:");
        print(player.pos.x); // Expected: 10. If 99, Deep Copy/COW failed.

        // --- 4. Logic Verification ---
        if player.score == 100 {
            if player.pos.x == 10 {
                print("COW Semantics: VERIFIED");
            } else {
                print("COW Semantics: FAILED (Nested leak)");
            }
        } else {
            print("COW Semantics: FAILED (Top-level leak)");
        }

        return 0;
    }
}
