program test_stdlib {
    fn main() {
        print("=== HLX Standard Library Test ===");

        // Test Math Functions
        print("--- Math Tests ---");

        print("sqrt(16) = ");
        let s = sqrt(16);
        print(s);  // Should be 4

        print("sqrt(100) = ");
        let s2 = sqrt(100);
        print(s2);  // Should be 10

        print("pow(2, 8) = ");
        let p = pow(2, 8);
        print(p);  // Should be 256

        print("pow(3, 4) = ");
        let p2 = pow(3, 4);
        print(p2);  // Should be 81

        // Test Vector Functions
        print("--- Vector Tests ---");

        // Create test vectors
        let v1 = vec_new(3);
        v1[0] = 3;
        v1[1] = 4;
        v1[2] = 0;

        print("v1 = [3, 4, 0]");
        print("vec_length(v1) = ");
        let len = vec_length(v1);
        print(len);  // Should be 5

        let v2 = vec_new(3);
        v2[0] = 1;
        v2[1] = 2;
        v2[2] = 3;

        let v3 = vec_new(3);
        v3[0] = 4;
        v3[1] = 5;
        v3[2] = 6;

        print("v2 = [1, 2, 3], v3 = [4, 5, 6]");

        let sum = vec_add(v2, v3);
        print("vec_add(v2, v3) = [");
        print(sum[0]);
        print(sum[1]);
        print(sum[2]);
        print("]");  // Should be [5, 7, 9]

        let diff = vec_sub(v3, v2);
        print("vec_sub(v3, v2) = [");
        print(diff[0]);
        print(diff[1]);
        print(diff[2]);
        print("]");  // Should be [3, 3, 3]

        let scaled = vec_scale(v2, 2);
        print("vec_scale(v2, 2) = [");
        print(scaled[0]);
        print(scaled[1]);
        print(scaled[2]);
        print("]");  // Should be [2, 4, 6]

        // Test Matrix Functions
        print("--- Matrix Tests ---");

        // Create 2x2 identity matrix
        let identity = mat_identity(2);
        print("Identity 2x2:");
        print(mat_get(identity, 0, 0, 2));
        print(mat_get(identity, 0, 1, 2));
        print(mat_get(identity, 1, 0, 2));
        print(mat_get(identity, 1, 1, 2));
        // Should be: 1 0 0 1

        // Create test matrix
        let m1 = mat_new(2, 2);
        mat_set(m1, 0, 0, 2, 1);
        mat_set(m1, 0, 1, 2, 2);
        mat_set(m1, 1, 0, 2, 3);
        mat_set(m1, 1, 1, 2, 4);

        print("Matrix m1 = [[1,2],[3,4]]");

        // Scalar multiplication
        let m2 = mat_scalar(m1, 2, 2, 2);
        print("mat_scalar(m1, 2) = ");
        print(mat_get(m2, 0, 0, 2));
        print(mat_get(m2, 0, 1, 2));
        print(mat_get(m2, 1, 0, 2));
        print(mat_get(m2, 1, 1, 2));
        // Should be: 2 4 6 8

        // Matrix transpose
        let mt = mat_transpose(m1, 2, 2);
        print("mat_transpose(m1) = ");
        print(mat_get(mt, 0, 0, 2));
        print(mat_get(mt, 0, 1, 2));
        print(mat_get(mt, 1, 0, 2));
        print(mat_get(mt, 1, 1, 2));
        // Should be: 1 3 2 4

        // Matrix multiplication (existing function)
        let m3 = mat_mul(m1, m1, 2, 2, 2);
        print("mat_mul(m1, m1) = ");
        print(mat_get(m3, 0, 0, 2));
        print(mat_get(m3, 0, 1, 2));
        print(mat_get(m3, 1, 0, 2));
        print(mat_get(m3, 1, 1, 2));
        // Should be: 7 10 15 22

        print("=== All Tests Complete ===");
        return 0;
    }
}
