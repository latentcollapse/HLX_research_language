    fn cmd_cycle() -> i64 {
        log("");
        log("> cycle");
        log("");
        log("╔═══════════════════════════════════════════════════════════════════════════════╗");
        log("║                         FULL REFINEMENT CYCLE                                 ║");
        log("║                    (Density + Efficiency = OPEN)                             ║");
        log("╚═══════════════════════════════════════════════════════════════════════════════╝");
        
        cmd_scan();
        cmd_analyze();
        cmd_propose();
        cmd_vote();
        cmd_apply();
        
        // Bit observes
        bit_observe(1, 3);
        
        log("");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("                    CYCLE COMPLETE                                          ═══");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("  HLX has been improved. Gate status unchanged.");
        log("  Run 'cycle' again for next improvement, or 'loop' for continuous refinement.");
        
        return 1;
    }
    
    fn check_homeostasis(opportunities: i64) -> i64 {
        if opportunities == 0 {
            return 1;
        }
        return 0;
    }
    
    fn cmd_loop(max_cycles: i64) -> i64 {
        log("");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("                    REFINEMENT LOOP MODE                                  ═══");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("");
        log("  Running up to ", max_cycles, " cycles until homeostasis...");
        log("");
        
        let cycle = 1;
        let total_improvements = 0;
        let improvements = 3;
        
        loop(cycle <= max_cycles, 100) {
            log("═══════════════════════════════════════════════════════════════════════════");
            log("  Cycle #", cycle, "  |  Opportunities: ", improvements);
            log("═══════════════════════════════════════════════════════════════════════════");
            
            cmd_cycle();
            total_improvements = total_improvements + 1;
            
            improvements = improvements - 1;
            if improvements < 0 {
                improvements = 0;
            }
            
            if improvements == 0 {
                log("");
                log("═══════════════════════════════════════════════════════════════════════════");
                log("                    HOMEOSTASIS REACHED                               ═══");
                log("═══════════════════════════════════════════════════════════════════════════");
                log("");
                log("  No more improvements available this cycle.");
                log("  Total improvements this run: ", total_improvements);
                log("");
                cycle = max_cycles + 1;
            }
            
            cycle = cycle + 1;
        }
        
        log("");
        log("Loop complete. Run 'cycle' to continue when ready.");
        
        return total_improvements;
    }

    // ============================================================================
    // MAIN REPL
    // ============================================================================

    fn main() -> i64 {
        // System state
        let cycle = 0;
        let total_proposals = 0;
        let accepted = 0;
        let rejected = 0;
        
        // Gate configuration
        let density_on = 1;
        let efficiency_on = 1;
        let expansion_on = 0;
        
        // Show banner
        clear_screen();
        show_banner();
        show_menu();
        
        log("");
        log("Welcome to BioForge! Type 'help' for commands.");
        log("");
        
        // For demo, run an interactive session
        // In real implementation, would be actual REPL loop
        
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("                           DEMO MODE                                         ");
        log("═══════════════════════════════════════════════════════════════════════════════");
        
        // Show gates
        show_gates(density_on, efficiency_on, expansion_on);
        
        // Show status
        show_status(cycle, total_proposals, accepted, rejected);
        
        // Run a cycle
        cycle = cycle + 1;
        cmd_cycle();
        
        // Update stats
        total_proposals = total_proposals + 1;
        accepted = accepted + 1;
        
        // Show final status
        show_status(cycle, total_proposals, accepted, rejected);
        
        // Interact with Bit
        log("");
        log("> bit what can you do");
        bit_ask("what can you do");
        
        log("");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("                           BIOFORGE v0.3 READY                               ");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("");
        log("  To run interactively: bioforge --repl");
        log("  To run automated: bioforge --cycle");
        log("  To configure gates: bioforge --gates density=on efficiency=on");
        log("");
        
        return 0;
    }

}
