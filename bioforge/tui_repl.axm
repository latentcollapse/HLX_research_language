    fn cmd_scan() -> i64 {
        log("");
        log("> scan");
        log("");
        log("═══ SCANNING HLX CODEBASE ═══");
        
        log("");
        log("  Scanning: hlx/hlx_bootstrap/");
        log("    + lexer.hlx     (21893 bytes)");
        log("    + parser.hlx    (73000 bytes)");
        log("    + compiler.hlx  (5600 bytes)");
        log("    + builtins.hlx  (21933 bytes)");
        
        log("");
        log("  Scanning: hlx-runtime/src/");
        log("    + vm.rs         (64528 bytes)");
        log("    + agent.rs      (5580 bytes)");
        log("    + rsi.rs        (36090 bytes)");
        
        log("");
        log("  Found 3 high-priority opportunities");
        
        return 3;
    }

    fn cmd_analyze() -> i64 {
        log("");
        log("> analyze");
        log("");
        log("═══ ANALYZING PATTERNS ═══");
        
        log("");
        log("  Opportunity 1: lexer.hlx:142");
        log("    Type: DENSITY");
        log("    Pattern: Repeated char_at() calls (42 occurrences)");
        log("    Severity: HIGH");
        log("    Benefit: Extract to helper function");
        
        log("");
        log("  Opportunity 2: parser.hlx:89");
        log("    Type: EFFICIENCY");
        log("    Pattern: O(n) token lookup");
        log("    Severity: MEDIUM");
        log("    Benefit: Binary search would be O(log n)");
        
        log("");
        log("  Opportunity 3: builtins.hlx:256");
        log("    Type: DENSITY");
        log("    Pattern: Repeated string comparison");
        log("    Severity: LOW");
        
        return 3;
    }

    fn cmd_propose() -> i64 {
        log("");
        log("> propose");
        log("");
        log("═══ GENERATING PROPOSAL ═══");
        
        log("");
        log("  [1] Architect designs improvement");
        log("      Title: Extract char_at_safe helper in lexer.hlx");
        log("      Type: DENSITY");
        
        log("");
        log("  [2] Coder generates implementation");
        log("      Code:");
        log("        fn char_at_safe(s: String, i: i64) -> String {");
        log("            let len = strlen(s);");
        log("            if i < 0 { return \"\"; }");
        log("            if i >= len { return \"\"; }");
        log("            return char_at(s, i);");
        log("        }");
        
        log("");
        log("  [3] Sentinel evaluates risk");
        log("      Risk: DENSITY (safe refactoring)");
        log("      Gate: ON - APPROVED");
        
        log("");
        log("  Proposal ready for Council vote.");
        
        return 1;
    }

