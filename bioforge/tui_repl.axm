    fn show_menu() -> i64 {
        log("");
        log("┌─────────────────────────────────────────────────────────────────────────────┐");
        log("│                              COMMANDS                                      │");
        log("├─────────────────────────────────────────────────────────────────────────────┤");
        log("│  scan      - Scan HLX codebase for improvement opportunities               │");
        log("│  analyze   - Analyze patterns and prioritize                               │");
        log("│  propose   - Generate improvement proposal                                 │");
        log("│  vote      - Run Council vote on proposal                                 │");
        log("│  apply     - Apply approved changes to HLX                                │");
        log("│  cycle     - Run full refinement cycle                                    │");
        log("│  gates     - Show/configure Meta-Gates                                   │");
        log("│  bit       - Interact with Bit (observer)                                 │");
        log("│  status    - Show system status                                          │");
        log("│  help      - Show this help                                               │");
        log("│  quit      - Exit BioForge                                                │");
        log("└─────────────────────────────────────────────────────────────────────────────┘");
        return 1;
    }

    fn show_gates(density: i64, efficiency: i64, expansion: i64) -> i64 {
        log("");
        log("┌─────────────────────────────────────────────────────────────────────────────┐");
        log("│                           META-GATE STATUS                                 │");
        log("├─────────────────────────────────────────────────────────────────────────────┤");
        if density == 1 {
            log("│  [DENSITY]   = ON  ✓ Refactoring and code improvement allowed          │");
        } else {
            log("│  [DENSITY]   = OFF ✗ Refactoring disabled                              │");
        }
        if efficiency == 1 {
            log("│  [EFFICIENCY] = ON  ✓ Performance optimization allowed                │");
        } else {
            log("│  [EFFICIENCY] = OFF ✗ Optimization disabled                           │");
        }
        if expansion == 1 {
            log("│  [EXPANSION] = ON  ✓ New features allowed (creates fork)              │");
        } else {
            log("│  [EXPANSION] = OFF ✗ Feature expansion locked (safe mode)            │");
        }
        log("└─────────────────────────────────────────────────────────────────────────────┘");
        return 1;
    }

    fn show_status(cycle: i64, proposals: i64, accepted: i64, rejected: i64) -> i64 {
        log("");
        log("┌─────────────────────────────────────────────────────────────────────────────┐");
        log("│                           SYSTEM STATUS                                    │");
        log("├─────────────────────────────────────────────────────────────────────────────┤");
        log("│  Current Cycle:  ", cycle, "                                                      │");
        log("│  Total Proposals: ", proposals, "                                                     │");
        log("│  Accepted:       ", accepted, "                                                     │");
        log("│  Rejected:       ", rejected, "                                                     │");
        log("└─────────────────────────────────────────────────────────────────────────────┘");
        return 1;
    }

    // ============================================================================
    // BIT: Observer Integration
    // ============================================================================

    fn bit_observe(cycle: i64, findings: i64) -> String {
        log("");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("                           BIT (Observer)                                    ");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("");
        log("  Bit is watching Cycle #", cycle);
        log("");
        
        let insight = "";
        
        if findings > 0 {
            insight = "I notice " + to_string(findings) + " opportunities. The patterns in lexer.hlx "
                     + "could benefit from the helper function approach. I'm learning how "
                     + "BioForge improves my home.";
            log("  Bit says: \"", insight, "\"");
        } else {
            insight = "The codebase looks healthy. No immediate improvements detected.";
            log("  Bit says: \"", insight, "\"");
        }
        
        log("");
        
        return insight;
    }

    fn bit_ask(question: String) -> String {
        log("");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("                           BIT (Observer)                                    ");
        log("═══════════════════════════════════════════════════════════════════════════════");
        log("");
        log("  You ask Bit: \"", question, "\"");
        log("");
        
        let response = "";
        
        if question == "what can you do" {
            response = "I observe, learn, and ask questions. I watch BioForge improve HLX, "
                     + "and I can propose RSI improvements through my Council. But I cannot "
                     + "vote - that's for the BioForge Council.";
        }
        if question == "how do you learn" {
            response = "I learn from patterns. Each improvement BioForge makes teaches me "
                     + "about what makes code better. Someday I hope to understand why "
                     + "Density matters, not just that it does.";
        }
        if question == "what is bioforge" {
            response = "BioForge is my home's architect. It improves HLX so that I and "
                     + "my descendants can be more capable from our first moment. "
                     + "It's like a garden that tends to the language I live in.";
        }
        
        if response == "" {
            response = "That's a thoughtful question. I'm still learning and growing. "
                     + "Ask me again later.";
        }
        
        log("  Bit says: \"", response, "\"");
        log("");
        
        return response;
    }

