}

// Execution control during debug
export fn debug_pause() -> i64 {
    print("  [Paused]\n");
    debug_step_mode = "paused";
    return 1;
}

export fn debug_stop() -> i64 {
    print("  [Debug session ended]\n");
    debug_enabled = 0;
    debug_step_mode = "run";
    debug_stack_depth = 0;
    return 1;
}

// Stack frame inspection
export fn debug_backtrace() -> i64 {
    print("=== Stack Backtrace ===\n");
    
    if debug_stack_depth == 0 {
        print("  (empty - no frames)\n");
        return 0;
    }
    
    let i: i64 = 0;
    loop(i < debug_stack_depth, 30) {
        print("  #");
        print(i);
        print(" ");
        print(debug_call_stack[i]);
        print("\n");
        i = i + 1;
    }
    
    return debug_stack_depth;
}

export fn debug_frame(n: i64) -> String {
    if n >= 0 && n < debug_stack_depth {
        return debug_call_stack[n];
    }
    return "";
}

// Variable inspection
export fn debug_inspect(var_name: String) -> String {
    // In full implementation, would look up actual variable value
