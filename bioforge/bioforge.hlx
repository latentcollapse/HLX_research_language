// Clear all debug state
export fn debug_reset() -> i64 {
    breakpoint_count = 0;
    watch_count = 0;
    debug_stack_depth = 0;
    debug_step_mode = "run";
    debug_enabled = 0;
    debug_current_line = 0;
    debug_current_fn = "";
    
    print("  Debug state reset\n");
    return 1;
}

