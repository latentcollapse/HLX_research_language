    print("    loop\n");
    print("    struct\n");
    print("    module\n");
    print("    import\n");
    print("    print\n");
    print("    return\n");
    
    return 1;  // Number of suggestions
}

// Go to definition
export fn lsp_definition(uri: String, line: i64, column: i64) -> String {
