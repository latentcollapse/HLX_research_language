// ============================================================================
// DEBUG ORGAN API (for external use)
// ============================================================================

export struct DebugSession {
    target: String;
    breakpoints: i64;
    watches: i64;
    status: String;  // idle, running, paused, stopped
}

// Create new debug session
export fn debug_session_new(target: String) -> DebugSession {
    let session: DebugSession;
    session.target = target;
    session.breakpoints = 0;
    session.watches = 0;
    session.status = "idle";
    return session;
}

// Start debugging
export fn debug_session_start(session: DebugSession) -> i64 {
    session.status = "running";
    debug_enabled = 1;
    return debug_run(session.target);
}

// End debug session  
export fn debug_session_end(session: DebugSession) -> i64 {
    session.status = "stopped";
    debug_stop();
    return 1;
}

// ============================================================================
// ORGAN: LSP - Language Server Protocol for HLX
// ============================================================================

// LSP state
let lsp_enabled: i64 = 0;
let lsp_workspace_root: String = "";
let lsp_open_buffers: [String; 20];
let lsp_buffer_count: i64 = 0;
let lsp_symbols: [String; 200];
let lsp_symbol_count: i64 = 0;

// LSP configuration
let lsp_max_problems: i64 = 100;
let lsp_auto_complete: i64 = 1;
let lsp_format_on_save: i64 = 0;

// Symbol kinds
let SYMBOL_FUNCTION: i64 = 1;
let SYMBOL_VARIABLE: i64 = 2;
let SYMBOL_TYPE: i64 = 3;
let SYMBOL_MODULE: i64 = 4;
let SYMBOL_CONSTANT: i64 = 5;

struct LspSymbol {
    name: String;
    kind: i64;
    file: String;
    line: i64;
    column: i64;
}

let lsp_symbol_table: [LspSymbol; 200];

// Text document sync
export fn lsp_did_open(uri: String, text: String) -> i64 {
    print("=== LSP: Document opened ===\n");
    print("  URI: ");
    print(uri);
    print("\n");
    
    if lsp_buffer_count < 20 {
        lsp_open_buffers[lsp_buffer_count] = uri;
        lsp_buffer_count = lsp_buffer_count + 1;
    }
    
    // Index the document
    lsp_index_document(uri, text);
    
    return 1;
}

export fn lsp_did_change(uri: String, text: String) -> i64 {
    // Re-index on change
    lsp_index_document(uri, text);
    return 1;
}

export fn lsp_did_close(uri: String) -> i64 {
    print("  Document closed: ");
    print(uri);
    print("\n");
    return 1;
}

fn lsp_index_document(uri: String, text: String) -> i64 {
    // Extract symbols from the document
    // In full implementation, would parse and extract:
    // - Function definitions
    // - Variable declarations
    // - Type definitions
    // - Module imports
    
    print("  Indexing: ");
    print(uri);
    print("\n");
    
    // Placeholder - would do actual parsing
    lsp_symbol_count = 0;
    
    return 1;
}

