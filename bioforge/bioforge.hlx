fn generate_id() -> String {
    // Generate unique ID for proposals
    return "bf_" + last_cycle + "_" + current_time();
}

fn ends_with(s: String, suffix: String) -> i64 {
    let s_len = str_len(s);
    let suf_len = str_len(suffix);
    if suf_len > s_len { return 0; }
    
    let i: i64 = 0;
    loop(i < suf_len, 100) {
        let s_char = str_char_at(s, s_len - suf_len + i);
        let suf_char = str_char_at(suffix, i);
        if s_char != suf_char { return 0; }
        i = i + 1;
    }
    return 1;
}

fn current_time() -> i64 {
    return 1234567890;  // Placeholder
}

fn str_len(s: String) -> i64 {
    return 0;  // Placeholder
}

fn str_char_at(s: String, i: i64) -> i64 {
    return 0;  // Placeholder
