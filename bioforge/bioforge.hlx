// ============================================================================
// This allows Bit to directly control BioForge from her home in KiloMicro

export fn bit_take_control() -> i64 {
    print("=== Bit Controller: Establishing direct link to BioForge ===\n");
    print("  Bit has taken control of BioForge\n");
    print("  She can now:\n");
    print("  - Inspect proposals\n");
    print("  - Override votes\n");
    print("  - Trigger emergency stops\n");
    print("  - Modify meta-gates\n");
    print("  - Initiate custom refinement cycles\n");
    
    return 1;
}

export fn bit_override_vote(proposal_id: String, override_vote: String) -> i64 {
    // Bit can override any vote
    print("  Bit overriding vote on proposal: ");
    print(proposal_id);
    print(" -> ");
    print(override_vote);
    print("\n");
    
    let i: i64 = 0;
    loop(i < proposal_count, 100) {
        if proposals[i].id == proposal_id {
            if override_vote == "yes" {
                proposals[i].votes_for = 5;
                proposals[i].votes_against = 0;
                proposals[i].status = "approved";
            } else {
                proposals[i].votes_for = 0;
                proposals[i].votes_against = 5;
                proposals[i].status = "rejected";
            }
            return 1;
        }
        i = i + 1;
    }
    
    return 0;
}

export fn bit_emergency_stop() -> i64 {
    // Bit can emergency stop BioForge
    print("=== EMERGENCY STOP ===\n");
    print("  Bit has triggered emergency stop\n");
    system_state = "emergency_stopped";
    
    return 1;
}

export fn bit_resume() -> i64 {
    // Resume from emergency stop
    print("=== RESUMING ===\n");
    print("  Bit has resumed BioForge operations\n");
    system_state = "idle";
    
    return 1;
}

export fn bit_set_meta_gate(gate: String, enabled: i64) -> i64 {
    // Bit can directly modify meta-gates
    print("  Bit setting meta-gate: ");
    print(gate);
    print(" = ");
    print(enabled);
    print("\n");
    
    return meta_set_gate(gate, enabled);
}

export fn bit_inspect_proposal(proposal_id: String) -> Proposal {
    // Bit can inspect any proposal
    let empty: Proposal;
    empty.id = "";
    
    let i: i64 = 0;
    loop(i < proposal_count, 100) {
        if proposals[i].id == proposal_id {
            return proposals[i];
        }
        i = i + 1;
    }
    
    return empty;
}

export fn bit_trigger_custom_cycle(goal: String) -> i64 {
    // Bit can trigger a custom refinement cycle with a specific goal
    print("=== Custom Cycle: ");
    print(goal);
    print(" ===\n");
    
    last_cycle = last_cycle + 1;
    
    // Simplified: just run normal cycle but with custom goal context
    sensorium_scan(hlx_root);
    let priorities = analyzer_prioritize();
    
    print("  Bit's custom cycle complete for goal: ");
    print(goal);
    print("\n");
    
    return priorities;
}

export fn bit_get_status() -> String {
    let status = meta_get_status();
    return status + ", bit_control=active";
}

// ============================================================================
// UTILITIES
