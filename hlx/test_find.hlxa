// Test array find operation
program test_find {
    fn main() {
        print("=== Testing Array Find ===");

        let arr = [1, 2, 3, 4];

        let idx1 = find(arr, 3);
        print("find(arr, 3):");
        print(idx1);

        let idx2 = find(arr, 99);
        print("find(arr, 99):");
        print(idx2);

        print("=== Done ===");
        return 0;
    }
}
