        // Summary
        print("\n");
        print("═══════════════════════════════════════════════════════════\n");
        print("RESULTS:\n");
        print("  Passed: ");
        print(passed);
        print("/28\n");
        print("  Failed: ");
        print(failed);
        print("/28\n");

        if (failed == 0) {
            print("\n✓ ALL TESTS PASSED!\n");
            print("═══════════════════════════════════════════════════════════\n");
            return 1;
        } else {
            print("\n✗ SOME TESTS FAILED\n");
            print("═══════════════════════════════════════════════════════════\n");
            return 0;
        }
    }
}
