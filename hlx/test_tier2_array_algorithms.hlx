        if (test_min_simple() == 1) {
            print("  ✓ min finds minimum value\n");
            passed += 1;
        } else {
            print("  ✗ min simple failed\n");
            failed += 1;
        }

        if (test_max_simple() == 1) {
            print("  ✓ max finds maximum value\n");
            passed += 1;
        } else {
            print("  ✗ max simple failed\n");
            failed += 1;
        }

        if (test_min_negative() == 1) {
            print("  ✓ min works with negatives\n");
            passed += 1;
        } else {
            print("  ✗ min negative failed\n");
            failed += 1;
        }

        print("\n");

        // Test reversal
        print("Testing array_reverse() function:\n");

        if (test_reverse_empty() == 1) {
            print("  ✓ reverse([]) works\n");
            passed += 1;
        } else {
            print("  ✗ reverse([]) failed\n");
            failed += 1;
        }

        if (test_reverse_single() == 1) {
            print("  ✓ reverse([42]) works\n");
            passed += 1;
        } else {
            print("  ✗ reverse([42]) failed\n");
            failed += 1;
        }

        if (test_reverse_multiple() == 1) {
            print("  ✓ reverse([1,2,3,4,5]) works\n");
            passed += 1;
