// Test dataflow analysis - uninitialized variable detection

program test {
    // Case 1: Definitely uninitialized (simplified - HLX always inits with `let`)
    fn test_use_before_init() {
        // In real HLX, this would be: let x = undefined;
        // For now, we'll test with assignment patterns
        let x;
        print(x);  // Should warn: x may be uninitialized
        return 0;
    }

    // Case 2: Conditional initialization
    fn test_conditional_init(flag) {
        let x;
        if (flag) {
            x = 10;
        }
        // x is maybe initialized here
        print(x);  // Should warn: x may be uninitialized on else path
        return 0;
    }

    // Case 3: Initialized before use (OK)
    fn test_proper_init() {
        let x = 5;
        print(x);  // OK - x is initialized
        return x;
    }

    // Case 4: Loop with initialization
    fn test_loop_init() {
        let x;
        let i = 0;
        loop(i < 10, 100) {
            x = i;
            i = i + 1;
        }
        print(x);  // OK - x is initialized in loop
        return 0;
    }
}
