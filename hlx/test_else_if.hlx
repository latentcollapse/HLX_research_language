program test {
    fn check(n: i64) -> i64 {
        if (n < 0) {
            return 0 - 1;
        } else if (n == 0) {
            return 0;
        } else if (n < 10) {
            return 1;
        } else {
            return 2;
        }
    }

    fn main() -> i64 {
        return check(5);
    }
}
