// Test HLX math functions (now native!)
program test_math {
    fn main() {
        print("=== Testing Native Math Functions ===");

        // Sqrt
        let s = sqrt(16.0);
        print("sqrt(16.0) =");
        print(s);  // Should be 4.0

        // Pow
        let p = pow(2.0, 8.0);
        print("pow(2, 8) =");
        print(p);  // Should be 256

        // Trig functions
        let pi = 3.14159265359;
        let s1 = sin(pi / 2.0);
        print("sin(pi/2) =");
        print(s1);  // Should be ~1.0

        let c1 = cos(0.0);
        print("cos(0) =");
        print(c1);  // Should be 1.0

        let t1 = tan(pi / 4.0);
        print("tan(pi/4) =");
        print(t1);  // Should be ~1.0

        // Exp and log
        let e = exp(1.0);
        print("exp(1) =");
        print(e);  // Should be ~2.718

        let l = log(e);
        print("log(e) =");
        print(l);  // Should be ~1.0

        // Floor, ceil, round
        let f = floor(3.7);
        print("floor(3.7) =");
        print(f);  // Should be 3

        let c = ceil(3.2);
        print("ceil(3.2) =");
        print(c);  // Should be 4

        let r = round(3.5);
        print("round(3.5) =");
        print(r);  // Should be 4

        // Abs
        let a1 = abs(-42);
        print("abs(-42) =");
        print(a1);  // Should be 42

        let a2 = abs(-3.14);
        print("abs(-3.14) =");
        print(a2);  // Should be 3.14

        print("=== All tests complete! ===");

        return 0;
    }
}
