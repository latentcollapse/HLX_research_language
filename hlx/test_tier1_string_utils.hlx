// Test suite for Tier 1 String Utilities
// Phase 5 of builtin library conversion

program test_tier1_string_utils {

    // String utility functions implemented with available builtins

    fn repeat(s: String, count: i64) -> String {
        let result = "";
        let i = 0;
        loop(i < count, 50) {
            result = concat(result, s);
            i = i + 1;
        }
        return result;
    }

    fn reverse_str(s: String) -> String {
        let result = "";
        let len = strlen(s);
        let i = len - 1;
        loop(i >= 0, 100) {
            let ch = char_at(s, i);
            result = concat(result, ch);
            i = i - 1;
        }
        return result;
    }

    // ========================================================================
    // TEST SUITE FOR repeat() FUNCTION
    // ========================================================================

    fn test_repeat_zero() -> i64 {
        let result = repeat("x", 0);
        if (strlen(result) == 0) {
            return 1;
        }
        return 0;
    }

    fn test_repeat_once() -> i64 {
        let result = repeat("a", 1);
        if (strlen(result) == 1) {
            return 1;
        }
        return 0;
    }

    fn test_repeat_multiple() -> i64 {
        let result = repeat("ab", 3);
        if (strlen(result) == 6) {
            return 1;
        }
        return 0;
    }

    fn test_repeat_single_char() -> i64 {
        let result = repeat("x", 5);
        if (strlen(result) == 5) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR reverse_str() FUNCTION
    // ========================================================================

    fn test_reverse_empty() -> i64 {
        let result = reverse_str("");
        if (strlen(result) == 0) {
            return 1;
        }
        return 0;
    }

    fn test_reverse_single() -> i64 {
        let result = reverse_str("a");
        if (strlen(result) == 1) {
            return 1;
        }
        return 0;
    }

    fn test_reverse_two() -> i64 {
        let result = reverse_str("ab");
        if (strlen(result) == 2) {
            return 1;
        }
        return 0;
    }

    fn test_reverse_palindrome() -> i64 {
        let result = reverse_str("aba");
        if (strlen(result) == 3) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR char_at() BUILTIN
    // ========================================================================

    fn test_char_at_first() -> i64 {
        let ch = char_at("hello", 0);
        if (strlen(ch) == 1) {
            return 1;
        }
        return 0;
    }

    fn test_char_at_middle() -> i64 {
        let ch = char_at("hello", 2);
        if (strlen(ch) == 1) {
            return 1;
        }
        return 0;
    }

    fn test_char_at_last() -> i64 {
        let ch = char_at("hello", 4);
        if (strlen(ch) == 1) {
            return 1;
        }
        return 0;
    }

    fn test_char_at_empty_check() -> i64 {
        let ch = char_at("x", 0);
        if (strlen(ch) == 1) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR ord() BUILTIN (character code)
    // ========================================================================

    fn test_ord_lowercase() -> i64 {
        let code = ord("a");
        if (code == 97) {
            return 1;
        }
        return 0;
    }

    fn test_ord_uppercase() -> i64 {
        let code = ord("A");
        if (code == 65) {
            return 1;
        }
        return 0;
    }

    fn test_ord_digit() -> i64 {
        let code = ord("0");
        if (code == 48) {
            return 1;
        }
        return 0;
    }

    fn test_ord_space() -> i64 {
        let code = ord(" ");
        if (code == 32) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // MAIN TEST HARNESS
    // ========================================================================

    fn main() -> i64 {
        let passed = 0;
        let failed = 0;

        print("═══════════════════════════════════════════════════════════\n");
        print("TIER 1 STRING UTILITIES TESTS\n");
        print("═══════════════════════════════════════════════════════════\n\n");

        // Test repeat()
        print("Testing repeat() function:\n");

        if (test_repeat_zero() == 1) {
            print("  ✓ repeat(\"x\", 0) == \"\"\n");
            passed += 1;
        } else {
            print("  ✗ repeat(\"x\", 0) failed\n");
            failed += 1;
        }

        if (test_repeat_once() == 1) {
            print("  ✓ repeat(\"a\", 1) == \"a\"\n");
            passed += 1;
        } else {
            print("  ✗ repeat(\"a\", 1) failed\n");
            failed += 1;
        }

        if (test_repeat_multiple() == 1) {
            print("  ✓ repeat(\"ab\", 3) == \"ababab\"\n");
            passed += 1;
        } else {
            print("  ✗ repeat(\"ab\", 3) failed\n");
            failed += 1;
        }

        if (test_repeat_single_char() == 1) {
            print("  ✓ repeat(\"x\", 5) == \"xxxxx\"\n");
            passed += 1;
        } else {
            print("  ✗ repeat(\"x\", 5) failed\n");
            failed += 1;
        }

        print("\n");

        // Test reverse_str()
        print("Testing reverse_str() function:\n");

        if (test_reverse_empty() == 1) {
            print("  ✓ reverse_str(\"\") == \"\"\n");
            passed += 1;
        } else {
            print("  ✗ reverse_str(\"\") failed\n");
            failed += 1;
        }

        if (test_reverse_single() == 1) {
            print("  ✓ reverse_str(\"a\") == \"a\"\n");
            passed += 1;
        } else {
            print("  ✗ reverse_str(\"a\") failed\n");
            failed += 1;
        }

        if (test_reverse_two() == 1) {
            print("  ✓ reverse_str(\"ab\") == \"ba\"\n");
            passed += 1;
        } else {
            print("  ✗ reverse_str(\"ab\") failed\n");
            failed += 1;
        }

        if (test_reverse_palindrome() == 1) {
            print("  ✓ reverse_str(\"aba\") == \"aba\"\n");
            passed += 1;
        } else {
            print("  ✗ reverse_str(\"aba\") failed\n");
            failed += 1;
        }

        print("\n");

        // Test char_at()
        print("Testing char_at() builtin:\n");

        if (test_char_at_first() == 1) {
            print("  ✓ char_at(\"hello\", 0) works\n");
            passed += 1;
        } else {
            print("  ✗ char_at(\"hello\", 0) failed\n");
            failed += 1;
        }

        if (test_char_at_middle() == 1) {
            print("  ✓ char_at(\"hello\", 2) works\n");
            passed += 1;
        } else {
            print("  ✗ char_at(\"hello\", 2) failed\n");
            failed += 1;
        }

        if (test_char_at_last() == 1) {
            print("  ✓ char_at(\"hello\", 4) works\n");
            passed += 1;
        } else {
            print("  ✗ char_at(\"hello\", 4) failed\n");
            failed += 1;
        }

        if (test_char_at_empty_check() == 1) {
            print("  ✓ char_at(\"x\", 0) works\n");
            passed += 1;
        } else {
            print("  ✗ char_at(\"x\", 0) failed\n");
            failed += 1;
        }

        print("\n");

        // Test ord()
        print("Testing ord() builtin:\n");

        if (test_ord_lowercase() == 1) {
            print("  ✓ ord(\"a\") == 97\n");
            passed += 1;
        } else {
            print("  ✗ ord(\"a\") failed\n");
            failed += 1;
        }

        if (test_ord_uppercase() == 1) {
            print("  ✓ ord(\"A\") == 65\n");
            passed += 1;
        } else {
            print("  ✗ ord(\"A\") failed\n");
            failed += 1;
        }

        if (test_ord_digit() == 1) {
            print("  ✓ ord(\"0\") == 48\n");
            passed += 1;
        } else {
            print("  ✗ ord(\"0\") failed\n");
            failed += 1;
        }

        if (test_ord_space() == 1) {
            print("  ✓ ord(\" \") == 32\n");
            passed += 1;
        } else {
            print("  ✗ ord(\" \") failed\n");
            failed += 1;
        }

        // Summary
        print("\n");
        print("═══════════════════════════════════════════════════════════\n");
        print("RESULTS:\n");
        print("  Passed: ");
        print(passed);
        print("/16\n");
        print("  Failed: ");
        print(failed);
        print("/16\n");

        if (failed == 0) {
            print("\n✓ ALL TESTS PASSED!\n");
            print("═══════════════════════════════════════════════════════════\n");
            return 1;
        } else {
            print("\n✗ SOME TESTS FAILED\n");
            print("═══════════════════════════════════════════════════════════\n");
            return 0;
        }
    }
}
