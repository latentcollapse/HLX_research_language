program test_ffi_lib {
    #[no_mangle]
    #[export]
    fn add(a: int, b: int) -> int {
        let c = a + b;
        return c;
    }

    #[export]
    fn multiply(x: int, y: int) -> int {
        let result = x * y;
        return result;
    }

    fn compute(n: int) -> int {
        let x = add(n, 10);
        let y = multiply(x, 2);
        return y;
    }
}
