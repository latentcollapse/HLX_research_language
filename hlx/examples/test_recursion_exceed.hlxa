// This test should FAIL with "Recursion depth exceeded" error

program test_recursion_exceed {
    #[max_depth(5)]
    fn countdown(n) {
        if n <= 0 {
            return 0;
        }
        return 1 + countdown(n - 1);
    }

    fn main() {
        print("Attempting to recurse 10 times with max_depth=5...");
        // This SHOULD error at runtime
        let result = countdown(10);
        print(result);
        return 0;
    }
}
