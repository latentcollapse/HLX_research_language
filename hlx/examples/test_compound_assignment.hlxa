// Test compound assignment operators

program test_compound_assignment {
    fn main() -> i64 {
        print("Testing compound assignment operators:");
        print("");

        // Test +=
        let x = 10;
        x += 5;
        print("x = 10; x += 5:");
        print(x);  // Should be 15

        // Test -=
        let y = 20;
        y -= 8;
        print("y = 20; y -= 8:");
        print(y);  // Should be 12

        // Test *=
        let z = 4;
        z *= 3;
        print("z = 4; z *= 3:");
        print(z);  // Should be 12

        // Test /=
        let a = 50;
        a /= 5;
        print("a = 50; a /= 5:");
        print(a);  // Should be 10

        // Test %=
        let b = 17;
        b %= 5;
        print("b = 17; b %= 5:");
        print(b);  // Should be 2

        // Test chaining
        let c = 100;
        c += 50;
        c *= 2;
        c -= 100;
        c /= 2;
        print("c = 100; c += 50; c *= 2; c -= 100; c /= 2:");
        print(c);  // Should be 50

        print("");
        print("All compound assignment tests passed!");
        return 0;
    }
}
