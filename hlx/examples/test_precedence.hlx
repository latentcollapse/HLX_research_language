// Test operator precedence

program test_precedence {
    fn main() -> i64 {
        print("Testing operator precedence:");
        print("");

        // Test 1: Addition before comparison
        // Should be: (2 + 3) < 10, not 2 + (3 < 10)
        let test1 = 2 + 3 < 10;
        print("2 + 3 < 10:");
        print(test1);  // Should be 1 (true) because 5 < 10

        // Test 2: Multiplication before addition
        // Should be: 2 + (3 * 4), not (2 + 3) * 4
        let test2 = 2 + 3 * 4;
        print("2 + 3 * 4:");
        print(test2);  // Should be 14, not 20

        // Test 3: Comparison before equality
        // Should be: (5 < 10) == 1, not 5 < (10 == 1)
        let test3 = 5 < 10 == 1;
        print("5 < 10 == 1:");
        print(test3);  // Should be 1 (true)

        // Test 4: Complex expression
        // Should be: ((1 + 2) * 3) < 10
        let test4 = 1 + 2 * 3 < 10;
        print("1 + 2 * 3 < 10:");
        print(test4);  // Should be 1 (true) because 7 < 10

        print("");
        print("All precedence tests passed!");
        return 0;
    }
}
