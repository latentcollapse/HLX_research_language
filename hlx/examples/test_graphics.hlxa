program test_graphics {
    fn main() {
        gfx_init();
        let display = gfx_open("HLX Iron Graphics", 640, 480);
        let win = display[0];
        let ren = display[1];

        let running = 1;
        loop(running == 1, 1000) {
            // Set color to Red
            gfx_color(ren, 255, 0, 0, 255);
            gfx_clear(ren);
            gfx_present(ren);

            if (gfx_poll()) {
                running = 0;
            }
        }

        gfx_quit();
        return 0;
    }
}
