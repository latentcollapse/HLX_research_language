// Test && and || operators

program test_logical_ops {
    fn main() -> i64 {
        print("Testing && and || operators:");
        print("");

        // Test && (and)
        let test1 = 1 == 1 and 2 == 2;
        print("1 == 1 and 2 == 2:");
        print(test1);  // Should be true

        let test2 = 1 == 1 and 2 == 3;
        print("1 == 1 and 2 == 3:");
        print(test2);  // Should be false

        // Test || (or)
        let test3 = 1 == 1 or 2 == 3;
        print("1 == 1 or 2 == 3:");
        print(test3);  // Should be true

        let test4 = 1 == 2 or 3 == 4;
        print("1 == 2 or 3 == 4:");
        print(test4);  // Should be false

        // Test precedence: and binds tighter than or
        // Should be: (1 == 1 and 2 == 2) or 3 == 4
        let test5 = 1 == 1 and 2 == 2 or 3 == 4;
        print("1 == 1 and 2 == 2 or 3 == 4:");
        print(test5);  // Should be true

        print("");
        print("Logical operators work!");
        return 0;
    }
}
