program test_tensor {
    fn main() {
        // A (2x2)
        let a = tensor_new(2, 2);
        tensor_set(a, 0, 0, 1); tensor_set(a, 0, 1, 2);
        tensor_set(a, 1, 0, 3); tensor_set(a, 1, 1, 4);

        // B (2x2)
        let b = tensor_new(2, 2);
        tensor_set(b, 0, 0, 10); tensor_set(b, 0, 1, 20);
        tensor_set(b, 1, 0, 30); tensor_set(b, 1, 1, 40);

        // Add
        let c = tensor_add_op(a, b);
        print(tensor_get(c, 0, 0)); // 11
        print(tensor_get(c, 0, 1)); // 22
        print(tensor_get(c, 1, 0)); // 33
        print(tensor_get(c, 1, 1)); // 44
        
        // Transpose A
        let t = tensor_t(a);
        print(tensor_get(t, 0, 0)); // 1
        print(tensor_get(t, 0, 1)); // 3
        print(tensor_get(t, 1, 0)); // 2
        print(tensor_get(t, 1, 1)); // 4
        
        return tensor_get(t, 1, 1);
    }
}
