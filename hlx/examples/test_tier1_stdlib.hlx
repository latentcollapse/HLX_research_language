program test_tier1_stdlib {
    fn main() {
        print("=== Testing Tier 1 Stdlib ===");

        // Test zeros and ones
        print("\n1. Testing zeros([2, 3]):");
        let z = zeros([2, 3]);
        print("Created zeros tensor");

        print("\n2. Testing ones([3, 2]):");
        let o = ones([3, 2]);
        print("Created ones tensor");

        // Test shape
        print("\n3. Testing shape():");
        let z_shape = shape(z);
        print("zeros shape:");
        print(z_shape);

        let o_shape = shape(o);
        print("ones shape:");
        print(o_shape);

        // Test size
        print("\n4. Testing size():");
        let z_size = size(z);
        print("zeros size:");
        print(z_size);

        let o_size = size(o);
        print("ones size:");
        print(o_size);

        // Test sum
        print("\n5. Testing sum():");
        let z_sum = sum(z);
        print("sum of zeros:");
        print(z_sum);

        let o_sum = sum(o);
        print("sum of ones:");
        print(o_sum);

        // Test mean
        print("\n6. Testing mean():");
        let z_mean = mean(z);
        print("mean of zeros:");
        print(z_mean);

        let o_mean = mean(o);
        print("mean of ones:");
        print(o_mean);

        // Test len (already existed)
        print("\n7. Testing len():");
        let arr = [1, 2, 3, 4, 5];
        print("Array:");
        print(arr);
        print("Length:");
        print(len(arr));

        print("\n=== All Tier 1 Tests Passed! ===");
    }
}
