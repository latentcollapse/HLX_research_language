// Test that variables are copies, not aliases

program test_aliasing {
    fn main() -> i64 {
        print("Testing variable aliasing fix:");
        print("");

        // Test 1: Simple aliasing
        let x = 5;
        let y = x;  // y should be a copy, not an alias
        print("Initial x:");
        print(x);  // Should be 5
        print("Initial y:");
        print(y);  // Should be 5

        // Now modify x
        x = 10;
        print("After x = 10:");
        print("x:");
        print(x);  // Should be 10
        print("y:");
        print(y);  // Should still be 5 (not 10!)

        // Test 2: In a loop (the original bug case)
        let pos = 0;
        let start = pos;  // start should be a copy
        pos = pos + 7;

        let diff = pos - start;  // Should be 7 (not 0!)
        print("");
        print("pos - start (should be 7):");
        print(diff);

        // Test 3: Multiple aliases
        let a = 100;
        let b = a;
        let c = a;
        a = 200;

        print("");
        print("After modifying a:");
        print("a:");
        print(a);  // 200
        print("b:");
        print(b);  // 100
        print("c:");
        print(c);  // 100

        print("");
        if y == 5 {
            if diff == 7 {
                if b == 100 {
                    print("All aliasing tests passed!");
                    return 0;
                }
            }
        }

        print("ERROR: Aliasing test failed!");
        return 1;
    }
}
