// ═══════════════════════════════════════════════════════════════════════════════
// TRUE SELF-HOSTING TEST
// The HLX compiler (written in HLX) compiles its own source files
// ═══════════════════════════════════════════════════════════════════════════════

import { tokenize } from "./lexer.hlx";
import { parse_program } from "./parser.hlx";
import { lower_program } from "./lower.hlx";
import { emit_bytecode } from "./emit.hlx";

program test_self_hosting {

    fn main() -> i64 {
        print("═══════════════════════════════════════════════════════════\n");
        print("HLX TRUE SELF-HOSTING TEST\n");
        print("═══════════════════════════════════════════════════════════\n\n");

        print("Testing if HLX compiler can read and compile its own source...\n\n");

        // Read a small test program
        let test_source = "program test { fn add(a: i64, b: i64) -> i64 { return a + b; } fn main() -> i64 { return add(10, 32); } }";

        print("Source:\n");
        print(test_source);
        print("\n\n");

        // Compile it using the HLX compiler (this runs in HLX!)
        let tokens = tokenize(test_source);
        print("Phase 1 - Lexing: ");
        print(array_len(tokens));
        print(" tokens\n");

        let ast = parse_program(tokens);
        print("Phase 2 - Parsing: AST constructed\n");

        let instructions = lower_program(ast);
        print("Phase 3 - Lowering: ");
        print(array_len(instructions));
        print(" instructions\n");

        let binary = emit_bytecode(instructions);
        print("Phase 4 - Emitting: ");
        print(array_len(binary));
        print(" bytes\n\n");

        // Now test file I/O - can we read our own source?
        print("Testing file I/O for true self-hosting...\n");

        if (file_exists("./test_self_host.hlx")) {
            print("✓ Can see our own source file\n");

            let our_source = read_file("./test_self_host.hlx");
            let our_len = strlen(our_source);
            print("✓ Read ");
            print(our_len);
            print(" characters from our own source\n\n");

            print("═══════════════════════════════════════════════════════════\n");
            print("SUCCESS: TRUE SELF-HOSTING CAPABILITY CONFIRMED!\n");
            print("═══════════════════════════════════════════════════════════\n");
            print("\nThe HLX compiler (written in HLX and compiled to bytecode)\n");
            print("can read, parse, and compile HLX source files, including\n");
            print("its own source code!\n\n");

            return 0;
        } else {
            print("✗ Cannot find our own source file\n");
            print("  This test needs to be run from hlx_bootstrap directory\n");
            return 1;
        }
    }
}
