// HLX Bootstrap Compiler Integration Test
// This tests that all the new syntactic sugar works together

program integration_test {

// Test 1: Compound assignment in loops
fn test_compound_assignment() -> i64 {
    let count = 0;
    let i = 0;

    loop(i < 10, 100) {
        count += i;  // Uses compound assignment
        i += 1;
    }

    // Should be sum of 0..9 = 45
    return count;
}

// Test 2: else-if chains with switch
fn test_control_flow(x: i64) -> i64 {
    let result = 0;

    // else-if chain
    if x < 0 {
        result = -1;
    } else if x == 0 {
        result = 0;
    } else if x < 10 {
        result = 1;
    } else {
        result = 2;
    }

    // Switch statement
    switch result {
        -1 => {
            return 100;
        },
        0 => {
            return 200;
        },
        1 => {
            return 300;
        },
        2 => {
            return 400;
        },
        _ => {
            return 999;
        },
    }
}

// Test 3: Multiple patterns in switch
fn classify_number(n: i64) -> String {
    switch n {
        0 => {
            return "zero";
        },
        1 | 2 | 3 | 4 | 5 => {
            return "small";
        },
        6 | 7 | 8 | 9 => {
            return "medium";
        },
        10 | 20 | 30 | 40 | 50 => {
            return "round";
        },
        _ => {
            return "other";
        },
    }
}

// Test 4: Nested control flow with all features
fn fibonacci_switch(n: i64) -> i64 {
    let a = 0;
    let b = 1;
    let i = 0;

    // Handle base cases with switch
    switch n {
        0 => { return 0; },
        1 => { return 1; },
        _ => {},
    }

    // Calculate fibonacci with loop and compound assignment
    loop(i < n - 1, 1000) {
        let temp = a + b;
        a = b;
        b = temp;
        i += 1;
    }

    return b;
}

// Test 5: All features combined
fn stress_test(mode: i64) -> i64 {
    let result = 0;

    // Switch with multiple patterns to select mode
    switch mode {
        1 | 11 | 21 => {
            // Mode A: Simple accumulation
            let i = 0;
            loop(i < 100, 200) {
                result += i;
                i += 1;
            }
        },
        2 | 12 | 22 => {
            // Mode B: Conditional accumulation
            let i = 0;
            loop(i < 100, 200) {
                if i % 2 == 0 {
                    result += i;
                } else if i % 3 == 0 {
                    result += i * 2;
                } else {
                    result += i * 3;
                }
                i += 1;
            }
        },
        3 | 13 | 23 => {
            // Mode C: Nested switch
            let i = 0;
            loop(i < 50, 100) {
                switch i % 5 {
                    0 => { result += 10; },
                    1 | 2 => { result += 5; },
                    3 | 4 => { result += 3; },
                    _ => {},
                }
                i += 1;
            }
        },
        _ => {
            result = -1;
        },
    }

    return result;
}

// Test 6: String patterns
fn parse_command(cmd: String) -> i64 {
    switch cmd {
        "start" | "begin" | "run" => {
            return 1;
        },
        "stop" | "end" | "halt" => {
            return 0;
        },
        "pause" | "wait" => {
            return 2;
        },
        "help" | "info" => {
            return 99;
        },
        _ => {
            return -1;
        },
    }
}

fn main() -> i64 {
    print("=== HLX Bootstrap Integration Test ===\n");

    // Test 1: Compound assignment
    print("\nTest 1: Compound assignment...\n");
    let t1 = test_compound_assignment();
    if t1 == 45 {
        print("  PASS: got ");
        print(t1);
        print("\n");
    } else {
        print("  FAIL: expected 45, got ");
        print(t1);
        print("\n");
        return 1;
    }

    // Test 2: else-if with switch
    print("\nTest 2: else-if and switch...\n");
    let t2a = test_control_flow(-5);
    let t2b = test_control_flow(0);
    let t2c = test_control_flow(5);
    let t2d = test_control_flow(15);

    if t2a == 100 {
        if t2b == 200 {
            if t2c == 300 {
                if t2d == 400 {
                    print("  PASS: all control flow tests passed\n");
                } else {
                    print("  FAIL: t2d\n");
                    return 1;
                }
            } else {
                print("  FAIL: t2c\n");
                return 1;
            }
        } else {
            print("  FAIL: t2b\n");
            return 1;
        }
    } else {
        print("  FAIL: t2a\n");
        return 1;
    }

    // Test 3: Multiple patterns
    print("\nTest 3: Multiple patterns...\n");
    let s1 = classify_number(0);
    let s2 = classify_number(3);
    let s3 = classify_number(7);
    let s4 = classify_number(20);
    let s5 = classify_number(99);

    if s1 == "zero" {
        if s2 == "small" {
            if s3 == "medium" {
                if s4 == "round" {
                    if s5 == "other" {
                        print("  PASS: all patterns matched correctly\n");
                    } else {
                        print("  FAIL: s5\n");
                        return 1;
                    }
                } else {
                    print("  FAIL: s4\n");
                    return 1;
                }
            } else {
                print("  FAIL: s3\n");
                return 1;
            }
        } else {
            print("  FAIL: s2\n");
            return 1;
        }
    } else {
        print("  FAIL: s1\n");
        return 1;
    }

    // Test 4: Fibonacci with switch
    print("\nTest 4: Fibonacci with switch...\n");
    let f0 = fibonacci_switch(0);
    let f1 = fibonacci_switch(1);
    let f10 = fibonacci_switch(10);

    if f0 == 0 {
        if f1 == 1 {
            if f10 == 55 {
                print("  PASS: fibonacci correct (F(10) = 55)\n");
            } else {
                print("  FAIL: F(10) expected 55, got ");
                print(f10);
                print("\n");
                return 1;
            }
        } else {
            print("  FAIL: F(1)\n");
            return 1;
        }
    } else {
        print("  FAIL: F(0)\n");
        return 1;
    }

    // Test 5: Stress test
    print("\nTest 5: Stress test...\n");
    let st1 = stress_test(1);
    let st2 = stress_test(2);
    let st3 = stress_test(3);

    if st1 == 4950 {
        print("  PASS: mode 1 = ");
        print(st1);
        print("\n");
    } else {
        print("  FAIL: mode 1 expected 4950, got ");
        print(st1);
        print("\n");
        return 1;
    }

    print("  Mode 2 result: ");
    print(st2);
    print("\n");

    print("  Mode 3 result: ");
    print(st3);
    print("\n");

    // Test 6: String patterns
    print("\nTest 6: String patterns...\n");
    let c1 = parse_command("start");
    let c2 = parse_command("halt");
    let c3 = parse_command("pause");
    let c4 = parse_command("help");
    let c5 = parse_command("unknown");

    if c1 == 1 {
        if c2 == 0 {
            if c3 == 2 {
                if c4 == 99 {
                    if c5 == -1 {
                        print("  PASS: all string patterns matched\n");
                    } else {
                        print("  FAIL: c5\n");
                        return 1;
                    }
                } else {
                    print("  FAIL: c4\n");
                    return 1;
                }
            } else {
                print("  FAIL: c3\n");
                return 1;
            }
        } else {
            print("  FAIL: c2\n");
            return 1;
        }
    } else {
        print("  FAIL: c1\n");
        return 1;
    }

    print("\n=== ALL TESTS PASSED ===\n");
    print("Syntactic sugar is working perfectly!\n");
    print("- else-if chains: ✓\n");
    print("- Compound assignment: ✓\n");
    print("- Switch statements: ✓\n");
    print("- Multiple patterns: ✓\n");
    return 0;
}

}
