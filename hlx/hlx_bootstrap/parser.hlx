// HLX Bootstrap Parser - Tokens to AST
// Takes token stream from lexer and builds an Abstract Syntax Tree

module parser {

// ============================================================================
// AST Node Type Constants
// ============================================================================

// Expression types
fn EXPR_INT() -> i64 { return 1; }
fn EXPR_STRING() -> i64 { return 2; }
fn EXPR_IDENT() -> i64 { return 3; }
fn EXPR_BINOP() -> i64 { return 4; }
fn EXPR_CALL() -> i64 { return 5; }
fn EXPR_ARRAY() -> i64 { return 6; }
fn EXPR_INDEX() -> i64 { return 7; }
fn EXPR_UNARY() -> i64 { return 8; }
fn EXPR_CONTRACT() -> i64 { return 9; }
fn EXPR_CONTRACT_FIELD() -> i64 { return 25; }
fn EXPR_FIELD_ACCESS() -> i64 { return 26; }
fn EXPR_COLLAPSE() -> i64 { return 27; }
fn EXPR_RESOLVE() -> i64 { return 28; }
fn EXPR_ADDRESS_OF() -> i64 { return 29; }
fn EXPR_DEREF() -> i64 { return 30; }
// ============================================================================
// PHASE 1: RECURSIVE INTELLIGENCE EXPRESSIONS
// ============================================================================
fn EXPR_LATENT_REF() -> i64 { return 31; }      // Reference to latent state
fn EXPR_EPOCH_REF() -> i64 { return 32; }       // Reference to epoch
fn EXPR_BARRIER_WAIT() -> i64 { return 33; }    // Barrier wait expression
fn EXPR_CONSENSUS() -> i64 { return 34; }       // Consensus result
fn EXPR_FITNESS() -> i64 { return 35; }         // Fitness evaluation

// Type node types
fn TYPE_IDENT() -> i64 { return 100; }
fn TYPE_POINTER() -> i64 { return 101; }
fn TYPE_ARRAY() -> i64 { return 102; }

// Statement types
fn STMT_LET() -> i64 { return 10; }
fn STMT_ASSIGN() -> i64 { return 11; }
fn STMT_IF() -> i64 { return 12; }
fn STMT_LOOP() -> i64 { return 13; }
fn STMT_RETURN() -> i64 { return 14; }
fn STMT_EXPR() -> i64 { return 15; }
fn STMT_BREAK() -> i64 { return 16; }
fn STMT_CONTINUE() -> i64 { return 17; }
fn STMT_MODULE() -> i64 { return 18; }
fn STMT_IMPORT() -> i64 { return 19; }
fn STMT_EXPORT() -> i64 { return 20; }
// ============================================================================
// PHASE 1: RECURSIVE INTELLIGENCE STATEMENTS
// ============================================================================
fn STMT_AGENT() -> i64 { return 30; }          // recursive agent definition
fn STMT_CYCLE() -> i64 { return 31; }          // cycle block
fn STMT_HALT() -> i64 { return 32; }           // halt when condition
fn STMT_SYNC() -> i64 { return 33; }           // sync at barrier
fn STMT_GOVERN() -> i64 { return 34; }         // govern block
fn STMT_MODIFY() -> i64 { return 35; }         // modify self block
fn STMT_DISSOLVABLE() -> i64 { return 36; }    // dissolvable agent
fn STMT_ON_DISSOLVE() -> i64 { return 37; }    // on_dissolve handler
fn STMT_CHANNEL() -> i64 { return 38; }        // channel declaration
fn STMT_AGGREGATE() -> i64 { return 39; }      // aggregate at barrier
fn STMT_LATENT() -> i64 { return 40; }         // latent state declaration
fn STMT_ACTION() -> i64 { return 41; }         // action definition
fn STMT_SWITCH() -> i64 { return 42; }         // switch expression/statement
fn STMT_CASE() -> i64 { return 43; }           // case clause

// STMT_SWITCH: [kind(42), discriminant_expr_ptr, cases_ptr, default_body_ptr]
// switch discriminant { case pattern => body, ... default => body }
fn make_stmt_switch(discriminant: [i64], cases: [i64], default_body: [i64]) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_SWITCH());
    node = set_at(node, 1, ptr_to_int(discriminant));
    node = set_at(node, 2, ptr_to_int(cases));
    node = set_at(node, 3, ptr_to_int(default_body));
    return node;
}

// STMT_CASE: [kind(43), pattern_value, body_ptr]
// pattern_value is the integer value to match (for now, ints only)
fn make_stmt_case(pattern: i64, body: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, STMT_CASE());
    node = set_at(node, 1, pattern);
    node = set_at(node, 2, ptr_to_int(body));
    return node;
}

// Block/Function types
fn NODE_FUNCTION() -> i64 { return 60; }
fn NODE_PROGRAM() -> i64 { return 61; }
// ============================================================================
// PHASE 1: RECURSIVE INTELLIGENCE TOP-LEVEL NODES
// ============================================================================
fn NODE_CLUSTER() -> i64 { return 62; }        // scale cluster definition
fn NODE_BARRIER() -> i64 { return 63; }        // barrier definition
fn NODE_CHANNEL() -> i64 { return 64; }        // channel definition
fn NODE_AGENT() -> i64 { return 65; }          // agent instance

// Binary operators
fn OP_ADD() -> i64 { return 30; }
fn OP_SUB() -> i64 { return 31; }
fn OP_MUL() -> i64 { return 32; }
fn OP_DIV() -> i64 { return 33; }
fn OP_MOD() -> i64 { return 34; }
fn OP_EQ() -> i64 { return 35; }
fn OP_NE() -> i64 { return 36; }
fn OP_LT() -> i64 { return 37; }
fn OP_LE() -> i64 { return 38; }
fn OP_GT() -> i64 { return 39; }
fn OP_GE() -> i64 { return 40; }
fn OP_AND() -> i64 { return 41; }
fn OP_OR() -> i64 { return 42; }
fn OP_BIT_AND() -> i64 { return 45; }
fn OP_BIT_OR() -> i64 { return 46; }
fn OP_BIT_XOR() -> i64 { return 47; }
fn OP_SHL() -> i64 { return 49; }
fn OP_SHR() -> i64 { return 50; }
fn OP_NOT() -> i64 { return 56; }

// ============================================================================
// Parser State
// ============================================================================

// Parser state: [tokens, pos, error_msg]
fn make_parser(tokens: [i64]) -> [i64] {
    let state = [0, 0, 0];  // Will store: tokens ref, pos, error
    state = set_at(state, 0, ptr_to_int(tokens));
    state = set_at(state, 1, 0);  // pos = 0
    state = set_at(state, 2, 0);  // no error
    return state;
}

fn parser_tokens(state: [i64]) -> [i64] {
    let ptr = get_at(state, 0);
    return int_to_ptr(ptr);
}

fn parser_pos(state: [i64]) -> i64 {
    return get_at(state, 1);
}

fn parser_set_pos(state: [i64], pos: i64) -> [i64] {
    return set_at(state, 1, pos);
}

fn parser_has_error(state: [i64]) -> i64 {
    let err = get_at(state, 2);
    if err != 0 { return 1; }
    return 0;
}

// ============================================================================
// Token Access Helpers
// ============================================================================

fn current_token(state: [i64]) -> [i64] {
    let tokens = parser_tokens(state);
    let pos = parser_pos(state);
    let len = array_len(tokens);
    if pos >= len {
        return get_at(tokens, len - 1);  // Return EOF
    }
    return get_at(tokens, pos);
}

fn peek_kind(state: [i64]) -> i64 {
    let tok = current_token(state);
    return get_at(tok, 0);  // kind
}

fn advance(state: [i64]) -> [i64] {
    let pos = parser_pos(state);
    return parser_set_pos(state, pos + 1);
}

fn expect(state: [i64], expected_kind: i64) -> [i64] {
    let kind = peek_kind(state);
    if kind != expected_kind {
        print("Parse error: expected token kind ");
        print_int(expected_kind);
        print(" but got ");
        print_int(kind);
        print("\n");
        // Set error flag
        state = set_at(state, 2, 1);
        return state;
    }
    return advance(state);
}

// ============================================================================
// AST Construction Helpers
// ============================================================================

fn make_expr_int(value: i64) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_INT());
    node = set_at(node, 1, value);
    return node;
}

fn make_expr_string(str: String) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_STRING());
    node = set_at(node, 1, ptr_to_int(str));
    return node;
}

fn make_expr_ident(name: String) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_IDENT());
    node = set_at(node, 1, ptr_to_int(name));
    return node;
}

fn make_expr_binop(op: i64, left: [i64], right: [i64]) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, EXPR_BINOP());
    node = set_at(node, 1, op);
    node = set_at(node, 2, ptr_to_int(left));
    node = set_at(node, 3, ptr_to_int(right));
    return node;
}

fn make_expr_unary(op: i64, operand: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, EXPR_UNARY());
    node = set_at(node, 1, op);
    node = set_at(node, 2, ptr_to_int(operand));
    return node;
}

fn make_expr_call(func_name: String, args: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, EXPR_CALL());
    node = set_at(node, 1, ptr_to_int(func_name));
    node = set_at(node, 2, ptr_to_int(args));
    return node;
}

fn make_expr_array(elements: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_ARRAY());
    node = set_at(node, 1, ptr_to_int(elements));
    return node;
}

fn make_expr_index(array: [i64], index: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, EXPR_INDEX());
    node = set_at(node, 1, ptr_to_int(array));
    node = set_at(node, 2, ptr_to_int(index));
    return node;
}

fn make_expr_contract(contract_id: i64, fields: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, EXPR_CONTRACT());
    node = set_at(node, 1, contract_id);
    node = set_at(node, 2, ptr_to_int(fields));
    return node;
}

fn make_expr_contract_field(field_id: i64, value: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, EXPR_CONTRACT_FIELD());
    node = set_at(node, 1, field_id);
    node = set_at(node, 2, ptr_to_int(value));
    return node;
}

fn make_expr_field_access(object: [i64], field_id: i64) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, EXPR_FIELD_ACCESS());
    node = set_at(node, 1, ptr_to_int(object));
    node = set_at(node, 2, field_id);
    return node;
}

fn make_expr_collapse(value: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_COLLAPSE());
    node = set_at(node, 1, ptr_to_int(value));
    return node;
}

fn make_expr_resolve(handle: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_RESOLVE());
    node = set_at(node, 1, ptr_to_int(handle));
    return node;
}

fn make_expr_address_of(operand: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_ADDRESS_OF());
    node = set_at(node, 1, ptr_to_int(operand));
    return node;
}

fn make_expr_deref(operand: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_DEREF());
    node = set_at(node, 1, ptr_to_int(operand));
    return node;
}

// ============================================================================
// Type Node Constructors
// ============================================================================

fn make_type_ident(name: String) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, TYPE_IDENT());
    node = set_at(node, 1, ptr_to_int(name));
    return node;
}

fn make_type_pointer(is_mut: i64, inner_type: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, TYPE_POINTER());
    node = set_at(node, 1, is_mut);
    node = set_at(node, 2, ptr_to_int(inner_type));
    return node;
}

fn make_type_array(element_type: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, TYPE_ARRAY());
    node = set_at(node, 1, ptr_to_int(element_type));
    return node;
}

// ============================================================================
// Statement Node Constructors
// ============================================================================

fn make_stmt_let(name: String, type_ann: [i64], value: [i64]) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_LET());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(type_ann));  // Can be 0 for no type annotation
    node = set_at(node, 3, ptr_to_int(value));
    return node;
}

fn make_stmt_assign(lhs: [i64], value: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, STMT_ASSIGN());
    node = set_at(node, 1, ptr_to_int(lhs));
    node = set_at(node, 2, ptr_to_int(value));
    return node;
}

fn make_stmt_if(cond: [i64], then_body: [i64], else_body: [i64]) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_IF());
    node = set_at(node, 1, ptr_to_int(cond));
    node = set_at(node, 2, ptr_to_int(then_body));
    node = set_at(node, 3, ptr_to_int(else_body));
    return node;
}

fn make_stmt_loop(cond: [i64], max_iter: i64, body: [i64]) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_LOOP());
    node = set_at(node, 1, ptr_to_int(cond));
    node = set_at(node, 2, max_iter);
    node = set_at(node, 3, ptr_to_int(body));
    return node;
}

fn make_stmt_return(value: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, STMT_RETURN());
    node = set_at(node, 1, ptr_to_int(value));
    return node;
}

fn make_stmt_expr(expr: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, STMT_EXPR());
    node = set_at(node, 1, ptr_to_int(expr));
    return node;
}

fn make_stmt_break() -> [i64] {
    let node = [0];
    node = set_at(node, 0, STMT_BREAK());
    return node;
}

fn make_stmt_continue() -> [i64] {
    let node = [0];
    node = set_at(node, 0, STMT_CONTINUE());
    return node;
}

fn make_stmt_module(name: String, body: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, STMT_MODULE());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(body));
    return node;
}

fn make_stmt_import(name: String) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, STMT_IMPORT());
    node = set_at(node, 1, ptr_to_int(name));
    return node;
}

fn make_stmt_export(item: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, STMT_EXPORT());
    node = set_at(node, 1, ptr_to_int(item));
    return node;
}

fn make_function(name: String, params: [i64], body: [i64], attributes: [i64]) -> [i64] {
    let node = [0, 0, 0, 0, 0];
    node = set_at(node, 0, NODE_FUNCTION());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(params));
    node = set_at(node, 3, ptr_to_int(body));
    node = set_at(node, 4, ptr_to_int(attributes));  // NEW: attributes array
    return node;
}

fn make_program(functions: [i64]) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, NODE_PROGRAM());
    node = set_at(node, 1, ptr_to_int(functions));
    return node;
}

// ============================================================================
// PHASE 1: RECURSIVE INTELLIGENCE AST NODES
// ============================================================================

// STMT_AGENT: [kind(30), name_ptr, latents_ptr, takes_ptr, gives_ptr, cycles_ptr, body_ptr, govern_ptr, modify_ptr]
// recursive agent Name { latent* takes? gives? cycle* stmt* govern? modify? }
fn make_stmt_agent(
    name: String, 
    latents: [i64],
    takes: [i64],
    gives: [i64],
    cycles: [i64],
    body: [i64], 
    govern: [i64],
    modify: [i64]
) -> [i64] {
    let node = [0, 0, 0, 0, 0, 0, 0, 0, 0];
    node = set_at(node, 0, STMT_AGENT());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(latents));
    node = set_at(node, 3, ptr_to_int(takes));
    node = set_at(node, 4, ptr_to_int(gives));
    node = set_at(node, 5, ptr_to_int(cycles));
    node = set_at(node, 6, ptr_to_int(body));
    node = set_at(node, 7, ptr_to_int(govern));
    node = set_at(node, 8, ptr_to_int(modify));
    return node;
}

// STMT_CYCLE: [kind(31), level_ptr, count, body_ptr]
// cycle outer(3) { ... }
fn make_stmt_cycle(level: String, count: i64, body: [i64]) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_CYCLE());
    node = set_at(node, 1, ptr_to_int(level));
    node = set_at(node, 2, count);
    node = set_at(node, 3, ptr_to_int(body));
    return node;
}

// STMT_HALT: [kind(32), condition_ptr, max_steps]
// halt when condition or steps >= N
fn make_stmt_halt(condition: [i64], max_steps: i64) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, STMT_HALT());
    node = set_at(node, 1, ptr_to_int(condition));
    node = set_at(node, 2, max_steps);
    return node;
}

// STMT_GOVERN: [kind(34), effect_ptr, conscience_ptr, trust_ptr]
// govern { effect: WRITE; conscience: [path_safety]; trust: INTERNAL; }
fn make_stmt_govern(effect: String, conscience: [i64], trust: String) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_GOVERN());
    node = set_at(node, 1, ptr_to_int(effect));
    node = set_at(node, 2, ptr_to_int(conscience));
    node = set_at(node, 3, ptr_to_int(trust));
    return node;
}

// STMT_LATENT: [kind(40), name_ptr, type_ptr, init_value_ptr]
// latent z_high: Tensor[512] = zeros(512)
fn make_stmt_latent(name: String, type_ann: [i64], init: [i64]) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_LATENT());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(type_ann));
    node = set_at(node, 3, ptr_to_int(init));
    return node;
}

// STMT_ACTION: [kind(41), name_ptr, params_ptr, body_ptr, govern_ptr]
// action name(params) { body } govern { ... }
fn make_stmt_action(name: String, params: [i64], body: [i64], govern: [i64]) -> [i64] {
    let node = [0, 0, 0, 0, 0];
    node = set_at(node, 0, STMT_ACTION());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(params));
    node = set_at(node, 3, ptr_to_int(body));
    node = set_at(node, 4, ptr_to_int(govern));
    return node;
}

// ============================================================================
// PHASE 2: SCALE CLUSTER NODES
// ============================================================================

// NODE_CLUSTER: [kind(62), name_ptr, agents_ptr, barriers_ptr, channels_ptr]
// scale cluster Name { agents: [...]; barriers: [...]; channels: [...]; }
fn make_node_cluster(name: String, agents: [i64], barriers: [i64], channels: [i64]) -> [i64] {
    let node = [0, 0, 0, 0, 0];
    node = set_at(node, 0, NODE_CLUSTER());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(agents));
    node = set_at(node, 3, ptr_to_int(barriers));
    node = set_at(node, 4, ptr_to_int(channels));
    return node;
}

// NODE_BARRIER: [kind(63), id, consensus_ptr, timeout, aggregation_ptr]
// barrier sync { consensus: cross_model_family; timeout: 30; aggregate: mean; }
fn make_node_barrier(id: i64, consensus: String, timeout: i64, aggregation: String) -> [i64] {
    let node = [0, 0, 0, 0, 0];
    node = set_at(node, 0, NODE_BARRIER());
    node = set_at(node, 1, id);
    node = set_at(node, 2, ptr_to_int(consensus));
    node = set_at(node, 3, timeout);
    node = set_at(node, 4, ptr_to_int(aggregation));
    return node;
}

// NODE_CHANNEL: [kind(64), name_ptr, capacity, policy_ptr]
// channel broadcast { capacity: 100; policy: fifo; }
fn make_node_channel(name: String, capacity: i64, policy: String) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, NODE_CHANNEL());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, capacity);
    node = set_at(node, 3, ptr_to_int(policy));
    return node;
}

// STMT_SYNC: [kind(33), barrier_id, consensus_type_ptr, timeout]
// sync at barrier { consensus: cross_model_family; timeout: 30; }
fn make_stmt_sync(barrier_id: i64, consensus: String, timeout: i64) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_SYNC());
    node = set_at(node, 1, barrier_id);
    node = set_at(node, 2, ptr_to_int(consensus));
    node = set_at(node, 3, timeout);
    return node;
}

// STMT_CHANNEL: [kind(38), name_ptr, capacity, policy_ptr]
fn make_stmt_channel(name: String, capacity: i64, policy: String) -> [i64] {
    let node = [0, 0, 0, 0];
    node = set_at(node, 0, STMT_CHANNEL());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, capacity);
    node = set_at(node, 3, ptr_to_int(policy));
    return node;
}

// ============================================================================
// PHASE 4: SELF-MODIFICATION NODES
// ============================================================================

// STMT_MODIFY: [kind(35), target_ptr, gates_ptr, budget_ptr, cooldown, body_ptr]
// modify self { gate proof { ... } budget { ... } cooldown: 5; }
fn make_stmt_modify(target: String, gates: [i64], budget: [i64], cooldown: i64, body: [i64]) -> [i64] {
    let node = [0, 0, 0, 0, 0, 0];
    node = set_at(node, 0, STMT_MODIFY());
    node = set_at(node, 1, ptr_to_int(target));
    node = set_at(node, 2, ptr_to_int(gates));
    node = set_at(node, 3, ptr_to_int(budget));
    node = set_at(node, 4, cooldown);
    node = set_at(node, 5, ptr_to_int(body));
    return node;
}

// ============================================================================
// PHASE 5: DISSOLVABLE AGENT NODES
// ============================================================================

// STMT_DISSOLVABLE: [kind(36), name_ptr, lifetime_ptr, inherit_ptr, body_ptr, on_dissolve_ptr]
// dissolvable agent Name { lifetime: task_completion; inherit: parent.x; ... }
fn make_stmt_dissolvable(
    name: String, 
    lifetime: [i64], 
    inherit: [i64], 
    body: [i64], 
    on_dissolve: [i64]
) -> [i64] {
    let node = [0, 0, 0, 0, 0, 0];
    node = set_at(node, 0, STMT_DISSOLVABLE());
    node = set_at(node, 1, ptr_to_int(name));
    node = set_at(node, 2, ptr_to_int(lifetime));
    node = set_at(node, 3, ptr_to_int(inherit));
    node = set_at(node, 4, ptr_to_int(body));
    node = set_at(node, 5, ptr_to_int(on_dissolve));
    return node;
}

// STMT_ON_DISSOLVE: [kind(37), archive_ptr, report_ptr]
// on_dissolve { archive: state -> parent.memory; report: summary -> parent.channel; }
fn make_stmt_on_dissolve(archive: [i64], report: [i64]) -> [i64] {
    let node = [0, 0, 0];
    node = set_at(node, 0, STMT_ON_DISSOLVE());
    node = set_at(node, 1, ptr_to_int(archive));
    node = set_at(node, 2, ptr_to_int(report));
    return node;
}

// ============================================================================
// EXPRESSION NODES
// ============================================================================

// EXPR_LATENT_REF: [kind(31), name_ptr]
// Reference to a latent state variable
fn make_expr_latent_ref(name: String) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_LATENT_REF());
    node = set_at(node, 1, ptr_to_int(name));
    return node;
}

// EXPR_EPOCH_REF: [kind(32), epoch_num]
// Reference to an epoch number
fn make_expr_epoch_ref(num: i64) -> [i64] {
    let node = [0, 0];
    node = set_at(node, 0, EXPR_EPOCH_REF());
    node = set_at(node, 1, num);
    return node;
}

