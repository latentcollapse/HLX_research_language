// ============================================================================
// Type Parsing
// ============================================================================

fn parse_type(state: [i64]) -> [i64] {
    let kind = peek_kind(state);
    let type_node = 0;

    // Pointer type: *const T or *mut T
    if kind == TOK_STAR() {
        state = advance(state);
        let is_mut = 0;

        // Check for const or mut
        if peek_kind(state) == TOK_CONST() {
            state = advance(state);
            is_mut = 0;
        } else if peek_kind(state) == TOK_MUT() {
            state = advance(state);
            is_mut = 1;
        } else {
            // Default to const if neither specified
            is_mut = 0;
        }

        // Parse inner type recursively
        let inner_result = parse_type(state);
        let inner_type = int_to_ptr(get_at(inner_result, 0));
        state = int_to_ptr(get_at(inner_result, 1));

        type_node = ptr_to_int(make_type_pointer(is_mut, inner_type));
    }
    // Array type: [T]
    else if kind == TOK_LBRACKET() {
        state = advance(state);
        let elem_result = parse_type(state);
        let elem_type = int_to_ptr(get_at(elem_result, 0));
        state = int_to_ptr(get_at(elem_result, 1));
        state = expect(state, TOK_RBRACKET());
        type_node = ptr_to_int(make_type_array(elem_type));
    }
    // Simple identifier type: i64, String, etc.
    else if kind == TOK_IDENT() {
        let tokens = parser_tokens(state);
        let pos = parser_pos(state);
        let tok = get_at(tokens, pos);
        let name = int_to_ptr(get_at(tok, 1));
        state = advance(state);
        type_node = ptr_to_int(make_type_ident(name));
    }
    else {
        // Error: expected a type
        print("ERROR: Expected type, got token kind: ");
        print_int(kind);
        print("\n");
        type_node = ptr_to_int(make_type_ident("error"));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, type_node);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// ============================================================================
// Expression Parsing (Recursive Descent with Precedence)
// ============================================================================

// Note: Functions defined in reverse order due to dependencies
// parse_primary_expr -> parse_multiplicative_expr -> parse_additive_expr -> ...

fn parse_primary_expr(state: [i64]) -> [i64] {
    let kind = peek_kind(state);
    let expr = 0;

    // Unary NOT operator
    if kind == TOK_NOT() {
        state = advance(state);
        let operand_result = parse_primary_expr(state);
        let operand = get_at(operand_result, 0);
        state = int_to_ptr(get_at(operand_result, 1));
        expr = ptr_to_int(make_expr_unary(OP_NOT(), int_to_ptr(operand)));

        let ret = [0, 0];
        ret = set_at(ret, 0, expr);
        ret = set_at(ret, 1, ptr_to_int(state));
        return ret;
    }

    // Address-of operator: &var
    if kind == TOK_AMP() {
        state = advance(state);
        let operand_result = parse_primary_expr(state);
        let operand = get_at(operand_result, 0);
        state = int_to_ptr(get_at(operand_result, 1));
        expr = ptr_to_int(make_expr_address_of(int_to_ptr(operand)));

        let ret = [0, 0];
        ret = set_at(ret, 0, expr);
        ret = set_at(ret, 1, ptr_to_int(state));
        return ret;
    }

    // Dereference operator: *ptr
    if kind == TOK_STAR() {
        state = advance(state);
        let operand_result = parse_primary_expr(state);
        let operand = get_at(operand_result, 0);
        state = int_to_ptr(get_at(operand_result, 1));
        expr = ptr_to_int(make_expr_deref(int_to_ptr(operand)));

        let ret = [0, 0];
        ret = set_at(ret, 0, expr);
        ret = set_at(ret, 1, ptr_to_int(state));
        return ret;
    }

    // Integer literal
    if kind == TOK_INT() {
        let tok = current_token(state);
        let value = get_at(tok, 1);  // Token stores value directly
        expr = ptr_to_int(make_expr_int(value));
        state = advance(state);
    }
    // String literal
    else if kind == TOK_STRING() {
        let tok = current_token(state);
        let str_ptr = get_at(tok, 1);
        expr = ptr_to_int(make_expr_string(int_to_ptr(str_ptr)));
        state = advance(state);
    }
    // Identifier or function call
    else if kind == TOK_IDENT() {
        let tok = current_token(state);
        let name_ptr = get_at(tok, 1);
        let name = int_to_ptr(name_ptr);
        state = advance(state);

        // Check for function call
        if peek_kind(state) == TOK_LPAREN() {
            state = advance(state);  // consume (

            // Parse arguments
            let args = [];
            loop(peek_kind(state) != TOK_RPAREN(), 100) {
                if peek_kind(state) == TOK_RPAREN() { break; }

                let arg_result = parse_expression(state);
                let arg = get_at(arg_result, 0);
                state = int_to_ptr(get_at(arg_result, 1));
                args = push(args, arg);

                if peek_kind(state) == TOK_COMMA() {
                    state = advance(state);
                }
            }

            state = expect(state, TOK_RPAREN());
            expr = ptr_to_int(make_expr_call(name, args));
        }
        // Check for array indexing
        else if peek_kind(state) == TOK_LBRACKET() {
            state = advance(state);  // consume [
            let index_result = parse_expression(state);
            let index = get_at(index_result, 0);
            state = int_to_ptr(get_at(index_result, 1));
            state = expect(state, TOK_RBRACKET());

            expr = ptr_to_int(make_expr_index(make_expr_ident(name), int_to_ptr(index)));
        }
        // Check for field access: .@field_id
        else if peek_kind(state) == 46 {  // DOT token (46)
            let base_expr = make_expr_ident(name);
            loop(peek_kind(state) == 46, 100) {  // While we see dots
                state = advance(state);  // consume .
                if peek_kind(state) == TOK_AT() {
                    state = advance(state);  // consume @
                    let field_tok = current_token(state);
                    let field_id = get_at(field_tok, 1);
                    state = expect(state, TOK_INT());
                    base_expr = make_expr_field_access(base_expr, field_id);
                } else {
                    break;
                }
            }
            expr = ptr_to_int(base_expr);
        }
        else {
            expr = ptr_to_int(make_expr_ident(name));
        }
    }
    // Array literal
    else if kind == TOK_LBRACKET() {
        state = advance(state);  // consume [

        let elements = [];
        loop(peek_kind(state) != TOK_RBRACKET(), 100) {
            if peek_kind(state) == TOK_RBRACKET() { break; }

            let elem_result = parse_expression(state);
            let elem = get_at(elem_result, 0);
            state = int_to_ptr(get_at(elem_result, 1));
            elements = push(elements, elem);

            if peek_kind(state) == TOK_COMMA() {
                state = advance(state);
            }
        }

        state = expect(state, TOK_RBRACKET());
        expr = ptr_to_int(make_expr_array(elements));
    }
    // Contract literal: {contract_id:{@field_id:value, ...}}
    else if kind == TOK_LBRACE() {
        state = advance(state);  // consume {

        // Check if this is a contract literal by looking for an integer followed by colon
        let next_kind = peek_kind(state);
        let is_contract = 0;

        if next_kind == TOK_INT() {
            let saved_pos = parser_pos(state);
            state = advance(state);  // consume integer
            if peek_kind(state) == TOK_COLON() {
                is_contract = 1;
            }
            // Reset position
            state = parser_set_pos(state, saved_pos);
        }

        if is_contract == 1 {
            // Parse contract ID
            let tok = current_token(state);
            let contract_id = get_at(tok, 1);
            state = advance(state);  // consume integer
            state = expect(state, TOK_COLON());

            // Parse inner braces
            state = expect(state, TOK_LBRACE());

            // Parse contract fields: @field_id:value, ...
            let fields = [];
            loop(peek_kind(state) != TOK_RBRACE(), 100) {
                if peek_kind(state) == TOK_RBRACE() { break; }

                // Expect @field_id
                state = expect(state, TOK_AT());
                let field_tok = current_token(state);
                let field_id = get_at(field_tok, 1);
                state = expect(state, TOK_INT());
                state = expect(state, TOK_COLON());

                // Parse value expression
                let value_result = parse_expression(state);
                let value = get_at(value_result, 0);
                state = int_to_ptr(get_at(value_result, 1));

                // Create contract field node
                let field_node = make_expr_contract_field(field_id, int_to_ptr(value));
                fields = push(fields, field_node);

                if peek_kind(state) == TOK_COMMA() {
                    state = advance(state);
                }
            }

            state = expect(state, TOK_RBRACE());
            state = expect(state, TOK_RBRACE());
            expr = ptr_to_int(make_expr_contract(contract_id, fields));
        }
        else {
            // Not a contract, error
            print("Parse error: unexpected { - not a valid contract literal\n");
            state = set_at(state, 2, 1);
        }
    }
    // Parenthesized expression
    else if kind == TOK_LPAREN() {
        state = advance(state);  // consume (
        let inner_result = parse_expression(state);
        expr = get_at(inner_result, 0);
        state = int_to_ptr(get_at(inner_result, 1));
        state = expect(state, TOK_RPAREN());
    }
    // collapse() function call
    else if kind == TOK_COLLAPSE() {
        state = advance(state);  // consume collapse
        state = expect(state, TOK_LPAREN());
        let arg_result = parse_expression(state);
        let arg = get_at(arg_result, 0);
        state = int_to_ptr(get_at(arg_result, 1));
        state = expect(state, TOK_RPAREN());
        expr = ptr_to_int(make_expr_collapse(int_to_ptr(arg)));
    }
    // resolve() function call
    else if kind == TOK_RESOLVE() {
        state = advance(state);  // consume resolve
        state = expect(state, TOK_LPAREN());
        let arg_result = parse_expression(state);
        let arg = get_at(arg_result, 0);
        state = int_to_ptr(get_at(arg_result, 1));
        state = expect(state, TOK_RPAREN());
        expr = ptr_to_int(make_expr_resolve(int_to_ptr(arg)));
    }
    else {
        print("Parse error: unexpected token kind ");
        print_int(kind);
        print("\n");
        state = set_at(state, 2, 1);  // Set error
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, expr);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_multiplicative_expr(state: [i64]) -> [i64] {
    let result = parse_primary_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        let op = 0;

        if kind == TOK_STAR() {
            op = OP_MUL();
        } else if kind == TOK_SLASH() {
            op = OP_DIV();
        } else if kind == TOK_PERCENT() {
            op = OP_MOD();
        } else {
            break;
        }

        state = advance(state);
        let rhs_result = parse_primary_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(op, int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_additive_expr(state: [i64]) -> [i64] {
    let result = parse_multiplicative_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        let op = 0;

        if kind == TOK_PLUS() {
            op = OP_ADD();
        } else if kind == TOK_MINUS() {
            op = OP_SUB();
        } else {
            break;
        }

        state = advance(state);
        let rhs_result = parse_multiplicative_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(op, int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_shift_expr(state: [i64]) -> [i64] {
    let result = parse_additive_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        let op = 0;

        if kind == TOK_SHL() {
            op = OP_SHL();
        } else if kind == TOK_SHR() {
            op = OP_SHR();
        } else {
            break;
        }

        state = advance(state);
        let rhs_result = parse_additive_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(op, int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_comparison_expr(state: [i64]) -> [i64] {
    let result = parse_shift_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        let op = 0;

        if kind == TOK_LT() {
            op = OP_LT();
        } else if kind == TOK_LE() {
            op = OP_LE();
        } else if kind == TOK_GT() {
            op = OP_GT();
        } else if kind == TOK_GE() {
            op = OP_GE();
        } else {
            break;
        }

        state = advance(state);
        let rhs_result = parse_shift_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(op, int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_equality_expr(state: [i64]) -> [i64] {
    let result = parse_comparison_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        let op = 0;

        if kind == TOK_EQEQ() {
            op = OP_EQ();
        } else if kind == TOK_NE() {
            op = OP_NE();
        } else {
            break;
        }

        state = advance(state);
        let rhs_result = parse_comparison_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(op, int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_bit_and_expr(state: [i64]) -> [i64] {
    let result = parse_equality_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        if kind != TOK_AMP() { break; }

        state = advance(state);
        let rhs_result = parse_equality_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(OP_BIT_AND(), int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_bit_xor_expr(state: [i64]) -> [i64] {
    let result = parse_bit_and_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        if kind != TOK_CARET() { break; }

        state = advance(state);
        let rhs_result = parse_bit_and_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(OP_BIT_XOR(), int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_bit_or_expr(state: [i64]) -> [i64] {
    let result = parse_bit_xor_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(1 == 1, 100) {
        let kind = peek_kind(state);
        if kind != TOK_PIPE() { break; }

        state = advance(state);
        let rhs_result = parse_bit_xor_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(OP_BIT_OR(), int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_and_expr(state: [i64]) -> [i64] {
    let result = parse_bit_or_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(peek_kind(state) == TOK_AND(), 100) {
        if peek_kind(state) != TOK_AND() { break; }
        state = advance(state);

        let rhs_result = parse_bit_or_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(OP_AND(), int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_or_expr(state: [i64]) -> [i64] {
    let result = parse_and_expr(state);
    let lhs = get_at(result, 0);
    state = int_to_ptr(get_at(result, 1));

    loop(peek_kind(state) == TOK_OR(), 100) {
        if peek_kind(state) != TOK_OR() { break; }
        state = advance(state);

        let rhs_result = parse_and_expr(state);
        let rhs = get_at(rhs_result, 0);
        state = int_to_ptr(get_at(rhs_result, 1));

        lhs = make_expr_binop(OP_OR(), int_to_ptr(lhs), int_to_ptr(rhs));
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, lhs);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

fn parse_expression(state: [i64]) -> [i64] {
    return parse_or_expr(state);
}

// ============================================================================
// Statement Parsing
// ============================================================================

fn parse_statement(state: [i64]) -> [i64] {
    let kind = peek_kind(state);
    let stmt = 0;

    // let statement
    if kind == TOK_LET() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
        // Get identifier from previous token
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let ident_tok = get_at(tokens, pos);
        let name = int_to_ptr(get_at(ident_tok, 1));

        // Optional type annotation: : Type
        let type_ann = 0;
        if peek_kind(state) == TOK_COLON() {
            state = advance(state);  // Skip colon
            let type_result = parse_type(state);
            type_ann = get_at(type_result, 0);
            state = int_to_ptr(get_at(type_result, 1));
        }

        state = expect(state, TOK_EQ());
        let value_result = parse_expression(state);
        let value = get_at(value_result, 0);
        state = int_to_ptr(get_at(value_result, 1));
        state = expect(state, TOK_SEMICOLON());

        stmt = ptr_to_int(make_stmt_let(name, int_to_ptr(type_ann), int_to_ptr(value)));
    }
    // return statement
    else if kind == TOK_RETURN() {
        state = advance(state);
        let value_result = parse_expression(state);
        let value = get_at(value_result, 0);
        state = int_to_ptr(get_at(value_result, 1));
        state = expect(state, TOK_SEMICOLON());

        stmt = ptr_to_int(make_stmt_return(int_to_ptr(value)));
    }
    // break statement
    else if kind == TOK_BREAK() {
        state = advance(state);
        state = expect(state, TOK_SEMICOLON());
        stmt = ptr_to_int(make_stmt_break());
    }
    // continue statement
    else if kind == TOK_CONTINUE() {
        state = advance(state);
        state = expect(state, TOK_SEMICOLON());
        stmt = ptr_to_int(make_stmt_continue());
    }
    // module statement
    else if kind == TOK_MODULE() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let ident_tok = get_at(tokens, pos);
        let name = int_to_ptr(get_at(ident_tok, 1));

        state = expect(state, TOK_LBRACE());

        // Parse module body
        let body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            body = push(body, s);
        }
        state = expect(state, TOK_RBRACE());

        stmt = ptr_to_int(make_stmt_module(name, body));
    }
    // import statement
    else if kind == TOK_IMPORT() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let ident_tok = get_at(tokens, pos);
        let name = int_to_ptr(get_at(ident_tok, 1));

        state = expect(state, TOK_SEMICOLON());

        stmt = ptr_to_int(make_stmt_import(name));
    }
    // export statement
    else if kind == TOK_EXPORT() {
        state = advance(state);
        // Parse the item being exported (typically a function)
        let item_result = parse_statement(state);
        let item = get_at(item_result, 0);
        state = int_to_ptr(get_at(item_result, 1));

        stmt = ptr_to_int(make_stmt_export(int_to_ptr(item)));
    }
    // if statement
    else if kind == TOK_IF() {
        state = advance(state);
        state = expect(state, TOK_LPAREN());
        let cond_result = parse_expression(state);
        let cond = get_at(cond_result, 0);
        state = int_to_ptr(get_at(cond_result, 1));
        state = expect(state, TOK_RPAREN());
        state = expect(state, TOK_LBRACE());

        // Parse then body
        let then_body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            then_body = push(then_body, s);
        }
        state = expect(state, TOK_RBRACE());

        // Parse optional else or else-if
        let else_body = [];
        if peek_kind(state) == TOK_ELSE() {
            state = advance(state);
            // Check for else-if
            if peek_kind(state) == TOK_IF() {
                // else-if: parse as a single if statement in else block
                let else_if_result = parse_statement(state);
                let else_if_stmt = get_at(else_if_result, 0);
                state = int_to_ptr(get_at(else_if_result, 1));
                else_body = push(else_body, else_if_stmt);
            } else {
                // regular else block
                state = expect(state, TOK_LBRACE());
                loop(peek_kind(state) != TOK_RBRACE(), 1000) {
                    if peek_kind(state) == TOK_RBRACE() { break; }
                    let stmt_result = parse_statement(state);
                    let s = get_at(stmt_result, 0);
                    state = int_to_ptr(get_at(stmt_result, 1));
                    else_body = push(else_body, s);
                }
                state = expect(state, TOK_RBRACE());
            }
        }

        stmt = ptr_to_int(make_stmt_if(int_to_ptr(cond), then_body, else_body));
    }
    // switch statement (match-like pattern matching)
    else if kind == TOK_SWITCH() || kind == TOK_MATCH() {
        let switch_result = parse_switch_stmt(state);
        stmt = get_at(switch_result, 0);
        state = int_to_ptr(get_at(switch_result, 1));
    }
    // loop statement
    else if kind == TOK_LOOP() {
        state = advance(state);
        state = expect(state, TOK_LPAREN());
        let cond_result = parse_expression(state);
        let cond = get_at(cond_result, 0);
        state = int_to_ptr(get_at(cond_result, 1));
        state = expect(state, TOK_COMMA());

        // Parse max_iter
        let max_iter_result = parse_expression(state);
        let max_iter_expr = get_at(max_iter_result, 0);
        state = int_to_ptr(get_at(max_iter_result, 1));
        // For simplicity, assume max_iter is an integer literal
        let max_iter_node = int_to_ptr(max_iter_expr);
        let max_iter = get_at(max_iter_node, 1);

        state = expect(state, TOK_RPAREN());
        state = expect(state, TOK_LBRACE());

        // Parse body
        let body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            body = push(body, s);
        }
        state = expect(state, TOK_RBRACE());

        stmt = ptr_to_int(make_stmt_loop(int_to_ptr(cond), max_iter, body));
    }
    // ============================================================================
    // PHASE 1: RECURSIVE INTELLIGENCE STATEMENTS
    // ============================================================================
    // recursive agent definition
    else if kind == TOK_RECURSIVE() {
        let agent_result = parse_agent_def(state);
        stmt = get_at(agent_result, 0);
        state = int_to_ptr(get_at(agent_result, 1));
    }
    // halt statement
    else if kind == TOK_HALT() {
        let halt_result = parse_halt_stmt(state);
        stmt = get_at(halt_result, 0);
        state = int_to_ptr(get_at(halt_result, 1));
    }
    // action definition
    else if kind == TOK_ACTION() {
        let action_result = parse_action_def(state);
        stmt = get_at(action_result, 0);
        state = int_to_ptr(get_at(action_result, 1));
    }
    // latent declaration
    else if kind == TOK_LATENT() {
        let latent_result = parse_latent_decl(state);
        stmt = get_at(latent_result, 0);
        state = int_to_ptr(get_at(latent_result, 1));
    }
    // cycle block
    else if kind == TOK_CYCLE() {
        let cycle_result = parse_cycle_block(state);
        stmt = get_at(cycle_result, 0);
        state = int_to_ptr(get_at(cycle_result, 1));
    }
    // govern block (standalone)
    else if kind == TOK_GOVERN() {
        let govern_result = parse_govern_block(state);
        stmt = get_at(govern_result, 0);
        state = int_to_ptr(get_at(govern_result, 1));
    }
    // ============================================================================
    // PHASE 2: SCALE CLUSTER
    // ============================================================================
    else if kind == TOK_SCALE() {
        let cluster_result = parse_cluster_def(state);
        stmt = get_at(cluster_result, 0);
        state = int_to_ptr(get_at(cluster_result, 1));
    }
    // sync at barrier
    else if kind == TOK_SYNC() {
        state = advance(state);
        state = expect(state, TOK_BARRIER());
        
        // Optional barrier id
        let barrier_id = 0;
        if peek_kind(state) == TOK_IDENT() {
            state = advance(state);
        }
        
        state = expect(state, TOK_LBRACE());
        
        // Parse consensus
        let consensus = "";
        if peek_kind(state) == TOK_CONSENSUS() {
            state = advance(state);
            state = expect(state, TOK_COLON());
            state = expect(state, TOK_IDENT());
            let tokens = parser_tokens(state);
            let pos = parser_pos(state) - 1;
            let tok = get_at(tokens, pos);
            consensus = int_to_ptr(get_at(tok, 1));
        }
        
        // Parse timeout
        let timeout = 0;
        if peek_kind(state) == TOK_IDENT() {
            state = advance(state);
            state = expect(state, TOK_COLON());
            let to_result = parse_expression(state);
            let to_expr = int_to_ptr(get_at(to_result, 0));
            timeout = get_at(to_expr, 1);
            state = int_to_ptr(get_at(to_result, 1));
        }
        
        state = expect(state, TOK_RBRACE());
        state = expect(state, TOK_SEMICOLON());
        
        stmt = ptr_to_int(make_stmt_sync(0, consensus, timeout));
    }
    // ============================================================================
    // PHASE 4: SELF-MODIFICATION
    // ============================================================================
    else if kind == TOK_MODIFY() {
        let modify_result = parse_modify_block(state);
        stmt = get_at(modify_result, 0);
        state = int_to_ptr(get_at(modify_result, 1));
    }
    // ============================================================================
    // PHASE 5: DISSOLVABLE AGENT
    // ============================================================================
    else if kind == TOK_DISSOLVABLE() {
        let dissolvable_result = parse_dissolvable_agent(state);
        stmt = get_at(dissolvable_result, 0);
        state = int_to_ptr(get_at(dissolvable_result, 1));
    }
    // ============================================================================
    // PHASE 5 (OUROBOROS): AXIOMATIC SYNTAX
    // ============================================================================
    // try/catch statement
    else if kind == TOK_TRY() {
        state = advance(state);
        state = expect(state, TOK_LBRACE());

        let try_body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            try_body = push(try_body, s);
        }
        state = expect(state, TOK_RBRACE());

        state = expect(state, TOK_CATCH());

        // Optional error variable name
        let error_var = 0;
        if peek_kind(state) == TOK_IDENT() {
            state = advance(state);
            let tokens = parser_tokens(state);
            let pos = parser_pos(state) - 1;
            let tok = get_at(tokens, pos);
            error_var = get_at(tok, 1);
        }

        state = expect(state, TOK_LBRACE());

        let catch_body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            catch_body = push(catch_body, s);
        }
        state = expect(state, TOK_RBRACE());

        // Represent as a block containing try_body (node type 50 = try/catch)
        let try_node = [50, error_var, 0, 0];
        try_node = set_at(try_node, 2, ptr_to_int(try_body));
        try_node = set_at(try_node, 3, ptr_to_int(catch_body));
        stmt = ptr_to_int(try_node);
    }
    // throw statement
    else if kind == TOK_THROW() {
        state = advance(state);
        let value_result = parse_expression(state);
        let value = get_at(value_result, 0);
        state = int_to_ptr(get_at(value_result, 1));
        state = expect(state, TOK_SEMICOLON());

        let throw_node = [51, value, 0, 0];
        stmt = ptr_to_int(throw_node);
    }
    // intent declaration
    else if kind == TOK_INTENT() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let tok = get_at(tokens, pos);
        let intent_name = get_at(tok, 1);

        state = expect(state, TOK_LBRACE());

        let intent_body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            intent_body = push(intent_body, s);
        }
        state = expect(state, TOK_RBRACE());

        let intent_node = [52, intent_name, 0, 0];
        intent_node = set_at(intent_node, 2, ptr_to_int(intent_body));
        stmt = ptr_to_int(intent_node);
    }
    // for loop: for x in iterable { ... }
    else if kind == TOK_FOR() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let tok = get_at(tokens, pos);
        let var_name = get_at(tok, 1);

        // Expect "in" keyword (parsed as ident)
        state = advance(state);

        let iter_result = parse_expression(state);
        let iterable = get_at(iter_result, 0);
        state = int_to_ptr(get_at(iter_result, 1));

        state = expect(state, TOK_LBRACE());

        let for_body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            for_body = push(for_body, s);
        }
        state = expect(state, TOK_RBRACE());

        let for_node = [53, var_name, iterable, 0];
        for_node = set_at(for_node, 3, ptr_to_int(for_body));
        stmt = ptr_to_int(for_node);
    }
    // while loop: while condition { ... }
    else if kind == TOK_WHILE() {
        state = advance(state);
        let cond_result = parse_expression(state);
        let cond = get_at(cond_result, 0);
        state = int_to_ptr(get_at(cond_result, 1));

        state = expect(state, TOK_LBRACE());

        let while_body = [];
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            let stmt_result = parse_statement(state);
            let s = get_at(stmt_result, 0);
            state = int_to_ptr(get_at(stmt_result, 1));
            while_body = push(while_body, s);
        }
        state = expect(state, TOK_RBRACE());

        let while_node = [54, cond, 0, 0];
        while_node = set_at(while_node, 2, ptr_to_int(while_body));
        stmt = ptr_to_int(while_node);
    }
    // struct definition
    else if kind == TOK_STRUCT() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let tok = get_at(tokens, pos);
        let struct_name = get_at(tok, 1);

        state = expect(state, TOK_LBRACE());

        let fields = [];
        loop(peek_kind(state) != TOK_RBRACE(), 100) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            state = expect(state, TOK_IDENT());
            let ftokens = parser_tokens(state);
            let fpos = parser_pos(state) - 1;
            let ftok = get_at(ftokens, fpos);
            let field_name = get_at(ftok, 1);

            state = expect(state, TOK_COLON());
            let type_result = parse_type(state);
            state = int_to_ptr(get_at(type_result, 1));

            fields = push(fields, field_name);

            if peek_kind(state) == TOK_COMMA() {
                state = advance(state);
            }
        }
        state = expect(state, TOK_RBRACE());

        let struct_node = [55, struct_name, 0, 0];
        struct_node = set_at(struct_node, 2, ptr_to_int(fields));
        stmt = ptr_to_int(struct_node);
    }
    // extern function declaration
    else if kind == TOK_EXTERN() {
        state = advance(state);
        // Parse the function that follows
        let fn_result = parse_statement(state);
        let fn_stmt = get_at(fn_result, 0);
        state = int_to_ptr(get_at(fn_result, 1));

        let extern_node = [56, fn_stmt, 0, 0];
        stmt = ptr_to_int(extern_node);
    }
    // Expression statement or assignment
    else {
        let expr_result = parse_expression(state);
        let expr = get_at(expr_result, 0);
        state = int_to_ptr(get_at(expr_result, 1));

        // Check for assignment or compound assignment
        let kind = peek_kind(state);
        if kind == TOK_EQ() {
            state = advance(state);
            let value_result = parse_expression(state);
            let value = get_at(value_result, 0);
            state = int_to_ptr(get_at(value_result, 1));
            state = expect(state, TOK_SEMICOLON());

            stmt = ptr_to_int(make_stmt_assign(int_to_ptr(expr), int_to_ptr(value)));
        } else if kind == TOK_PLUS_EQ() {
            state = advance(state);
            let rhs_result = parse_expression(state);
            let rhs = get_at(rhs_result, 0);
            state = int_to_ptr(get_at(rhs_result, 1));
            let value = make_expr_binop(OP_ADD(), int_to_ptr(expr), int_to_ptr(rhs));
            state = expect(state, TOK_SEMICOLON());
            stmt = ptr_to_int(make_stmt_assign(int_to_ptr(expr), value));
        } else if kind == TOK_MINUS_EQ() {
            state = advance(state);
            let rhs_result = parse_expression(state);
            let rhs = get_at(rhs_result, 0);
            state = int_to_ptr(get_at(rhs_result, 1));
            let value = make_expr_binop(OP_SUB(), int_to_ptr(expr), int_to_ptr(rhs));
            state = expect(state, TOK_SEMICOLON());
            stmt = ptr_to_int(make_stmt_assign(int_to_ptr(expr), value));
        } else if kind == TOK_STAR_EQ() {
            state = advance(state);
            let rhs_result = parse_expression(state);
            let rhs = get_at(rhs_result, 0);
            state = int_to_ptr(get_at(rhs_result, 1));
            let value = make_expr_binop(OP_MUL(), int_to_ptr(expr), int_to_ptr(rhs));
            state = expect(state, TOK_SEMICOLON());
            stmt = ptr_to_int(make_stmt_assign(int_to_ptr(expr), value));
        } else if kind == TOK_SLASH_EQ() {
            state = advance(state);
            let rhs_result = parse_expression(state);
            let rhs = get_at(rhs_result, 0);
            state = int_to_ptr(get_at(rhs_result, 1));
            let value = make_expr_binop(OP_DIV(), int_to_ptr(expr), int_to_ptr(rhs));
            state = expect(state, TOK_SEMICOLON());
            stmt = ptr_to_int(make_stmt_assign(int_to_ptr(expr), value));
        } else if kind == TOK_PERCENT_EQ() {
            state = advance(state);
            let rhs_result = parse_expression(state);
            let rhs = get_at(rhs_result, 0);
            state = int_to_ptr(get_at(rhs_result, 1));
            let value = make_expr_binop(OP_MOD(), int_to_ptr(expr), int_to_ptr(rhs));
            state = expect(state, TOK_SEMICOLON());
            stmt = ptr_to_int(make_stmt_assign(int_to_ptr(expr), value));
        } else {
            state = expect(state, TOK_SEMICOLON());
            stmt = ptr_to_int(make_stmt_expr(int_to_ptr(expr)));
        }
    }

    let ret = [0, 0];
    ret = set_at(ret, 0, stmt);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// ============================================================================
// PHASE 1: RECURSIVE AGENT PARSING
// ============================================================================

// Parse latent state declaration: latent name: Type = value
fn parse_latent_decl(state: [i64]) -> [i64] {
    state = expect(state, TOK_LATENT());
    
    // Get name
    state = expect(state, TOK_IDENT());
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let name_tok = get_at(tokens, pos);
    let name = int_to_ptr(get_at(name_tok, 1));
    
    // Optional type annotation
    let type_ann = 0;
    if peek_kind(state) == TOK_COLON() {
        state = advance(state);
        let type_result = parse_type(state);
        type_ann = get_at(type_result, 0);
        state = int_to_ptr(get_at(type_result, 1));
    }
    
    // Optional initializer
    let init = 0;
    if peek_kind(state) == TOK_EQ() {
        state = advance(state);
        let init_result = parse_expression(state);
        init = get_at(init_result, 0);
        state = int_to_ptr(get_at(init_result, 1));
    }
    
    state = expect(state, TOK_SEMICOLON());
    
    let latent = make_stmt_latent(name, int_to_ptr(type_ann), int_to_ptr(init));
    let ret = [0, 0];
    ret = set_at(ret, 0, latent);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// Parse cycle block: cycle level(count) { body }
fn parse_cycle_block(state: [i64]) -> [i64] {
    state = expect(state, TOK_CYCLE());
    
    // Get level name (identifier)
    state = expect(state, TOK_IDENT());
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let level_tok = get_at(tokens, pos);
    let level = int_to_ptr(get_at(level_tok, 1));
    
    // Parse (count)
    state = expect(state, TOK_LPAREN());
    let count_result = parse_expression(state);
    let count_expr = int_to_ptr(get_at(count_result, 0));
    state = int_to_ptr(get_at(count_result, 1));
    // Extract integer value
    let count = get_at(count_expr, 1);
    state = expect(state, TOK_RPAREN());
    
    // Parse body
    state = expect(state, TOK_LBRACE());
    let body = [];
    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        let stmt_result = parse_statement(state);
        let s = get_at(stmt_result, 0);
        state = int_to_ptr(get_at(stmt_result, 1));
        body = push(body, s);
    }
    state = expect(state, TOK_RBRACE());
    
    let cycle = make_stmt_cycle(level, count, body);
    let ret = [0, 0];
    ret = set_at(ret, 0, cycle);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// Parse halt statement: halt when condition or steps >= N
fn parse_halt_stmt(state: [i64]) -> [i64] {
    state = expect(state, TOK_HALT());
    state = expect(state, TOK_WHEN());
    
    // Parse condition
    let cond_result = parse_expression(state);
    let condition = get_at(cond_result, 0);
    state = int_to_ptr(get_at(cond_result, 1));
    
    // Check for "or steps >= N"
    let max_steps = 0;
    if peek_kind(state) == TOK_OR_KW() {
        state = advance(state);
        state = expect(state, TOK_IDENT());  // "steps"
        state = expect(state, TOK_GE());      // ">="
        let steps_result = parse_expression(state);
        let steps_expr = int_to_ptr(get_at(steps_result, 0));
        max_steps = get_at(steps_expr, 1);
        state = int_to_ptr(get_at(steps_result, 1));
    }
    
    state = expect(state, TOK_SEMICOLON());
    
    let halt = make_stmt_halt(int_to_ptr(condition), max_steps);
    let ret = [0, 0];
    ret = set_at(ret, 0, halt);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// Parse govern block: govern { effect: X; conscience: [...]; trust: Y; }
fn parse_govern_block(state: [i64]) -> [i64] {
    state = expect(state, TOK_GOVERN());
    state = expect(state, TOK_LBRACE());
    
    let effect = "";
    let conscience = [];
    let trust = "";
    
    // Parse effect
    if peek_kind(state) == TOK_EFFECT() {
        state = advance(state);
        state = expect(state, TOK_COLON());
        state = expect(state, TOK_IDENT());
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let tok = get_at(tokens, pos);
        effect = int_to_ptr(get_at(tok, 1));
        state = expect(state, TOK_SEMICOLON());
    }
    
    // Parse conscience predicates
    if peek_kind(state) == TOK_CONSCIENCE() {
        state = advance(state);
        state = expect(state, TOK_COLON());
        state = expect(state, TOK_LBRACKET());
        
        loop(peek_kind(state) != TOK_RBRACKET(), 100) {
            if peek_kind(state) == TOK_RBRACKET() { break; }
            
            // Get predicate name (could be keyword or identifier)
            let tok = current_token(state);
            let pred_ptr = get_at(tok, 1);
            conscience = push(conscience, pred_ptr);
            state = advance(state);
            
            if peek_kind(state) == TOK_COMMA() {
                state = advance(state);
            }
        }
        state = expect(state, TOK_RBRACKET());
        state = expect(state, TOK_SEMICOLON());
    }
    
    // Parse trust level
    if peek_kind(state) == TOK_TRUST() {
        state = advance(state);
        state = expect(state, TOK_COLON());
        state = expect(state, TOK_IDENT());
        let tokens = parser_tokens(state);
        let pos = parser_pos(state) - 1;
        let tok = get_at(tokens, pos);
        trust = int_to_ptr(get_at(tok, 1));
        state = expect(state, TOK_SEMICOLON());
    }
    
    state = expect(state, TOK_RBRACE());
    
    let govern = make_stmt_govern(effect, conscience, trust);
    let ret = [0, 0];
    ret = set_at(ret, 0, govern);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// ============================================================================
// SWITCH STATEMENT PARSING
// ============================================================================

// Parse switch statement: switch discriminant { case pattern => body, ... default => body }
// Pattern can be: integer literal, or "_" for default
fn parse_switch_stmt(state: [i64]) -> [i64] {
    state = expect(state, TOK_SWITCH());
    
    // Parse discriminant expression
    let disc_result = parse_expression(state);
    let discriminant = get_at(disc_result, 0);
    state = int_to_ptr(get_at(disc_result, 1));
    
    state = expect(state, TOK_LBRACE());
    
    let cases = [];
    let default_body = [];
    
    // Parse cases until }
    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        
        let kind = peek_kind(state);
        
        // case pattern => body
        if kind == TOK_CASE() {
            state = advance(state);
            
            // Parse pattern (integer literal for now)
            let pattern = 0;
            if peek_kind(state) == TOK_INT() {
                let tok = current_token(state);
                pattern = get_at(tok, 1);
                state = advance(state);
            } else if peek_kind(state) == TOK_IDENT() {
                // Could be underscore for wildcard, or named pattern
                let tok = current_token(state);
                let name_ptr = get_at(tok, 1);
                let name = int_to_ptr(name_ptr);
                if strcmp(name, "_") == 0 {
                    pattern = 0 - 1;  // Wildcard marker
                }
                state = advance(state);
            }
            
            // Expect => (fat arrow)
            state = expect(state, TOK_FAT_ARROW());
            
            // Parse body (single statement or block)
            let body = [];
            if peek_kind(state) == TOK_LBRACE() {
                state = advance(state);
                loop(peek_kind(state) != TOK_RBRACE(), 1000) {
                    if peek_kind(state) == TOK_RBRACE() { break; }
                    let stmt_result = parse_statement(state);
                    let s = get_at(stmt_result, 0);
                    state = int_to_ptr(get_at(stmt_result, 1));
                    body = push(body, s);
                }
                state = expect(state, TOK_RBRACE());
            } else {
                let stmt_result = parse_statement(state);
                let s = get_at(stmt_result, 0);
                state = int_to_ptr(get_at(stmt_result, 1));
                body = push(body, s);
            }
            
            let case_node = make_stmt_case(pattern, body);
            cases = push(cases, ptr_to_int(case_node));
        }
        // default => body (or just "default" keyword)
        else if kind == TOK_DEFAULT() {
            state = advance(state);
            state = expect(state, TOK_FAT_ARROW());
            
            // Parse default body
            if peek_kind(state) == TOK_LBRACE() {
                state = advance(state);
                loop(peek_kind(state) != TOK_RBRACE(), 1000) {
                    if peek_kind(state) == TOK_RBRACE() { break; }
                    let stmt_result = parse_statement(state);
                    let s = get_at(stmt_result, 0);
                    state = int_to_ptr(get_at(stmt_result, 1));
                    default_body = push(default_body, s);
                }
                state = expect(state, TOK_RBRACE());
            } else {
                let stmt_result = parse_statement(state);
                let s = get_at(stmt_result, 0);
                state = int_to_ptr(get_at(stmt_result, 1));
                default_body = push(default_body, s);
            }
        }
        // underscore as default (alternative syntax)
        else if kind == TOK_IDENT() {
            // Check if it's underscore
            let tok = current_token(state);
            let name_ptr = get_at(tok, 1);
            let name = int_to_ptr(name_ptr);
            if strcmp(name, "_") == 0 {
                state = advance(state);
                state = expect(state, TOK_FAT_ARROW());
                
                // Parse default body
                if peek_kind(state) == TOK_LBRACE() {
                    state = advance(state);
                    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
                        if peek_kind(state) == TOK_RBRACE() { break; }
                        let stmt_result = parse_statement(state);
                        let s = get_at(stmt_result, 0);
                        state = int_to_ptr(get_at(stmt_result, 1));
                        default_body = push(default_body, s);
                    }
                    state = expect(state, TOK_RBRACE());
                } else {
                    let stmt_result = parse_statement(state);
                    let s = get_at(stmt_result, 0);
                    state = int_to_ptr(get_at(stmt_result, 1));
                    default_body = push(default_body, s);
                }
            } else {
                state = advance(state);  // Skip unknown
            }
        }
        else {
            state = advance(state);  // Skip unknown token
        }
        
        // Optional comma between cases
        if peek_kind(state) == TOK_COMMA() {
            state = advance(state);
        }
    }
    
    state = expect(state, TOK_RBRACE());
    
    let switch_node = make_stmt_switch(int_to_ptr(discriminant), cases, default_body);
    let ret = [0, 0];
    ret = set_at(ret, 0, ptr_to_int(switch_node));
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// Parse action definition: action name(params) { body } govern?
fn parse_action_def(state: [i64]) -> [i64] {
    state = expect(state, TOK_ACTION());
    
    // Get name
    state = expect(state, TOK_IDENT());
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let name_tok = get_at(tokens, pos);
    let name = int_to_ptr(get_at(name_tok, 1));
    
    // Parse parameters
    state = expect(state, TOK_LPAREN());
    let params = [];
    loop(peek_kind(state) != TOK_RPAREN(), 100) {
        if peek_kind(state) == TOK_RPAREN() { break; }
        
        state = expect(state, TOK_IDENT());
        let param_pos = parser_pos(state) - 1;
        let param_tok = get_at(tokens, param_pos);
        let param_name = get_at(param_tok, 1);
        params = push(params, param_name);
        
        // Optional type
        if peek_kind(state) == TOK_COLON() {
            state = advance(state);
            state = expect(state, TOK_IDENT());
        }
        
        if peek_kind(state) == TOK_COMMA() {
            state = advance(state);
        }
    }
    state = expect(state, TOK_RPAREN());
    
    // Parse body
    state = expect(state, TOK_LBRACE());
    let body = [];
    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        let stmt_result = parse_statement(state);
        let s = get_at(stmt_result, 0);
        state = int_to_ptr(get_at(stmt_result, 1));
        body = push(body, s);
    }
    state = expect(state, TOK_RBRACE());
    
    // Optional govern block
    let govern = [];
    if peek_kind(state) == TOK_GOVERN() {
        let govern_result = parse_govern_block(state);
        let g = get_at(govern_result, 0);
        state = int_to_ptr(get_at(govern_result, 1));
        govern = push(govern, g);
    }
    
    let action = make_stmt_action(name, params, body, govern);
    let ret = [0, 0];
    ret = set_at(ret, 0, action);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// Parse recursive agent: recursive agent Name { latent* cycle* stmt* govern? modify? }
fn parse_agent_def(state: [i64]) -> [i64] {
    state = expect(state, TOK_RECURSIVE());
    state = expect(state, TOK_AGENT());
    
    // Get name
    state = expect(state, TOK_IDENT());
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let name_tok = get_at(tokens, pos);
    let name = int_to_ptr(get_at(name_tok, 1));
    
    state = expect(state, TOK_LBRACE());
    
    // Parse latent declarations
    let latents = [];
    loop(peek_kind(state) == TOK_LATENT(), 100) {
        let latent_result = parse_latent_decl(state);
        let l = get_at(latent_result, 0);
        state = int_to_ptr(get_at(latent_result, 1));
        latents = push(latents, l);
    }
    
    // Parse takes declarations (intent inputs)
    let takes = [];
    if peek_kind(state) == TOK_TAKES() {
        state = advance(state);
        loop(peek_kind(state) == TOK_IDENT(), 100) {
            state = expect(state, TOK_IDENT());
            let tpos = parser_pos(state) - 1;
            let ttok = get_at(tokens, tpos);
            let param_name = get_at(ttok, 1);
            takes = push(takes, param_name);
            
            if peek_kind(state) == TOK_COLON() {
                state = advance(state);
                state = expect(state, TOK_IDENT());  // type
            }
            if peek_kind(state) == TOK_COMMA() {
                state = advance(state);
            }
            if peek_kind(state) != TOK_IDENT() { break; }
        }
    }
    
    // Parse gives declarations (intent outputs)
    let gives = [];
    if peek_kind(state) == TOK_GIVES() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
        let gpos = parser_pos(state) - 1;
        let gtok = get_at(tokens, gpos);
        let output_name = get_at(gtok, 1);
        gives = push(gives, output_name);
        
        if peek_kind(state) == TOK_COLON() {
            state = advance(state);
            state = expect(state, TOK_IDENT());  // type
        }
    }
    
    // Parse cycle blocks
    let cycles = [];
    loop(peek_kind(state) == TOK_CYCLE(), 100) {
        let cycle_result = parse_cycle_block(state);
        let c = get_at(cycle_result, 0);
        state = int_to_ptr(get_at(cycle_result, 1));
        cycles = push(cycles, c);
    }
    
    // Parse body statements (until govern, modify, or })
    let body = [];
    loop(peek_kind(state) != TOK_RBRACE() 
         && peek_kind(state) != TOK_GOVERN() 
         && peek_kind(state) != TOK_MODIFY(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        if peek_kind(state) == TOK_GOVERN() { break; }
        if peek_kind(state) == TOK_MODIFY() { break; }
        
        let stmt_result = parse_statement(state);
        let s = get_at(stmt_result, 0);
        state = int_to_ptr(get_at(stmt_result, 1));
        body = push(body, s);
    }
    
    // Parse optional govern block
    let govern = [];
    if peek_kind(state) == TOK_GOVERN() {
        let govern_result = parse_govern_block(state);
        let g = get_at(govern_result, 0);
        state = int_to_ptr(get_at(govern_result, 1));
        govern = push(govern, g);
    }
    
    // Parse optional modify block (placeholder for now)
    let modify = [];
    if peek_kind(state) == TOK_MODIFY() {
        state = advance(state);
        state = expect(state, TOK_IDENT());  // "self"
        state = expect(state, TOK_LBRACE());
        // Skip modify contents for now
        loop(peek_kind(state) != TOK_RBRACE(), 1000) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            state = advance(state);
        }
        state = expect(state, TOK_RBRACE());
    }
    
    state = expect(state, TOK_RBRACE());
    
    let agent = make_stmt_agent(name, latents, takes, gives, cycles, body, govern, modify);
    let ret = [0, 0];
    ret = set_at(ret, 0, agent);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// ============================================================================
// PHASE 2: SCALE CLUSTER PARSING
// ============================================================================

// Parse scale cluster (simplified for now)
fn parse_cluster_def(state: [i64]) -> [i64] {
    state = expect(state, TOK_SCALE());
    state = expect(state, TOK_CLUSTER());
    
    state = expect(state, TOK_IDENT());
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let name_tok = get_at(tokens, pos);
    let name = int_to_ptr(get_at(name_tok, 1));
    
    state = expect(state, TOK_LBRACE());
    
    let agents = [];
    let barriers = [];
    let channels = [];
    
    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        
        let kind = peek_kind(state);
        if kind == TOK_AGENTS() {
            state = advance(state);
            state = expect(state, TOK_COLON());
            state = expect(state, TOK_LBRACKET());
            loop(peek_kind(state) != TOK_RBRACKET(), 100) {
                if peek_kind(state) == TOK_RBRACKET() { break; }
                state = expect(state, TOK_IDENT());
                if peek_kind(state) == TOK_COMMA() { state = advance(state); }
            }
            state = expect(state, TOK_RBRACKET());
            state = expect(state, TOK_SEMICOLON());
        } else if kind == TOK_SYNC() || kind == TOK_BARRIER() {
            if kind == TOK_SYNC() { state = advance(state); }
            state = expect(state, TOK_BARRIER());
            if peek_kind(state) == TOK_IDENT() { state = advance(state); }
            state = expect(state, TOK_LBRACE());
            loop(peek_kind(state) != TOK_RBRACE(), 100) {
                if peek_kind(state) == TOK_RBRACE() { break; }
                state = advance(state);
            }
            state = expect(state, TOK_RBRACE());
        } else if kind == TOK_CHANNEL() {
            state = advance(state);
            state = expect(state, TOK_IDENT());
            state = expect(state, TOK_LBRACE());
            loop(peek_kind(state) != TOK_RBRACE(), 100) {
                if peek_kind(state) == TOK_RBRACE() { break; }
                state = advance(state);
            }
            state = expect(state, TOK_RBRACE());
        } else {
            state = advance(state);
        }
    }
    
    state = expect(state, TOK_RBRACE());
    
    let cluster = make_node_cluster(name, agents, barriers, channels);
    let ret = [0, 0];
    ret = set_at(ret, 0, cluster);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// ============================================================================
// PHASE 4: SELF-MODIFICATION PARSING
// ============================================================================

// Parse modify block: modify self { gate proof { ... } budget { ... } cooldown: N; }
fn parse_modify_block(state: [i64]) -> [i64] {
    state = expect(state, TOK_MODIFY());
    
    // Target (usually "self")
    state = expect(state, TOK_IDENT());
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let target_tok = get_at(tokens, pos);
    let target = int_to_ptr(get_at(target_tok, 1));
    
    state = expect(state, TOK_LBRACE());
    
    // Parse gates
    let gates = [];
    loop(peek_kind(state) == TOK_GATE(), 10) {
        state = advance(state);
        
        state = expect(state, TOK_IDENT()); // gate type (proof, consensus, human)
        let gpos = parser_pos(state) - 1;
        let gtok = get_at(tokens, gpos);
        let gate_type = get_at(gtok, 1);
        gates = push(gates, gate_type);
        
        state = expect(state, TOK_LBRACE());
        
        // Parse gate content (skip for now)
        loop(peek_kind(state) != TOK_RBRACE(), 100) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            state = advance(state);
        }
        
        state = expect(state, TOK_RBRACE());
    }
    
    // Parse budget
    let budget = [];
    if peek_kind(state) == TOK_BUDGET() {
        state = advance(state);
        state = expect(state, TOK_LBRACE());
        
        loop(peek_kind(state) != TOK_RBRACE(), 100) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            state = advance(state);
        }
        
        state = expect(state, TOK_RBRACE());
    }
    
    // Parse cooldown
    let cooldown = 0;
    if peek_kind(state) == TOK_COOLDOWN() {
        state = advance(state);
        state = expect(state, TOK_COLON());
        let cd_result = parse_expression(state);
        let cd_expr = int_to_ptr(get_at(cd_result, 0));
        cooldown = get_at(cd_expr, 1);
        state = int_to_ptr(get_at(cd_result, 1));
        state = expect(state, TOK_SEMICOLON());
    }
    
    // Parse body (proposals)
    let body = [];
    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        let stmt_result = parse_statement(state);
        let s = get_at(stmt_result, 0);
        state = int_to_ptr(get_at(stmt_result, 1));
        body = push(body, s);
    }
    
    state = expect(state, TOK_RBRACE());
    
    let modify = make_stmt_modify(target, gates, budget, cooldown, body);
    let ret = [0, 0];
    ret = set_at(ret, 0, modify);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// ============================================================================
// PHASE 5: DISSOLVABLE AGENT PARSING
// ============================================================================

// Parse dissolvable agent: dissolvable agent Name { lifetime: X; inherit: Y; body on_dissolve? }
fn parse_dissolvable_agent(state: [i64]) -> [i64] {
    state = expect(state, TOK_DISSOLVABLE());
    state = expect(state, TOK_AGENT());
    
    // Get name
    state = expect(state, TOK_IDENT());
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let name_tok = get_at(tokens, pos);
    let name = int_to_ptr(get_at(name_tok, 1));
    
    state = expect(state, TOK_LBRACE());
    
    // Parse lifetime
    let lifetime = [];
    if peek_kind(state) == TOK_LIFETIME() {
        state = advance(state);
        state = expect(state, TOK_COLON());
        
        // task_completion | timeout(N)
        if peek_kind(state) == TOK_IDENT() {
            state = advance(state);
        } else if peek_kind(state) == TOK_INT() {
            let lt_result = parse_expression(state);
            let lt = get_at(lt_result, 0);
            state = int_to_ptr(get_at(lt_result, 1));
            lifetime = push(lifetime, lt);
        }
        state = expect(state, TOK_SEMICOLON());
    }
    
    // Parse inherit
    let inherit = [];
    if peek_kind(state) == TOK_INHERIT() {
        state = advance(state);
        state = expect(state, TOK_COLON());
        
        loop(peek_kind(state) == TOK_IDENT(), 100) {
            state = expect(state, TOK_IDENT());
            let ipos = parser_pos(state) - 1;
            let itok = get_at(tokens, ipos);
            let inherited = get_at(itok, 1);
            inherit = push(inherit, inherited);
            
            if peek_kind(state) == TOK_COMMA() {
                state = advance(state);
            }
        }
        state = expect(state, TOK_SEMICOLON());
    }
    
    // Parse body
    let body = [];
    loop(peek_kind(state) != TOK_RBRACE() && peek_kind(state) != TOK_ON_DISSOLVE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        if peek_kind(state) == TOK_ON_DISSOLVE() { break; }
        
        let stmt_result = parse_statement(state);
        let s = get_at(stmt_result, 0);
        state = int_to_ptr(get_at(stmt_result, 1));
        body = push(body, s);
    }
    
    // Parse on_dissolve
    let on_dissolve = [];
    if peek_kind(state) == TOK_ON_DISSOLVE() {
        state = advance(state);
        state = expect(state, TOK_LBRACE());
        
        // Parse archive and report (simplified)
        loop(peek_kind(state) != TOK_RBRACE(), 100) {
            if peek_kind(state) == TOK_RBRACE() { break; }
            state = advance(state);
        }
        
        state = expect(state, TOK_RBRACE());
    }
    
    state = expect(state, TOK_RBRACE());
    
    let dissolvable = make_stmt_dissolvable(name, lifetime, inherit, body, on_dissolve);
    let ret = [0, 0];
    ret = set_at(ret, 0, dissolvable);
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

// ============================================================================
// Function and Program Parsing
// ============================================================================

// Parse attributes like #[max_depth(50)]
// Returns [attributes_array, updated_state]
fn parse_attributes(state: [i64]) -> [i64] {
    let attributes = [];

    // Parse all #[...] blocks before function
    loop(peek_kind(state) == TOK_LBRACKET(), 10) {
        state = expect(state, TOK_LBRACKET());

        // Get attribute content as string
        // For now, collect tokens until ]
        let attr_tokens = [];
        loop(peek_kind(state) != TOK_RBRACKET(), 10) {
            let tok = current_token(state);
            let kind = get_at(tok, 0);

            // Convert token to string representation
            if (kind == TOK_IDENT()) {
                let name_ptr = get_at(tok, 1);
                attr_tokens = push(attr_tokens, name_ptr);
            } else if (kind == TOK_INT()) {
                let val = get_at(tok, 1);
                // Convert integer to string
                let num_str = [0, 0];
                num_str = set_at(num_str, 0, val);
                attr_tokens = push(attr_tokens, ptr_to_int(num_str));
            }
            state = advance(state);
        }

        state = expect(state, TOK_RBRACKET());

        // Build attribute string from tokens
        if (array_len(attr_tokens) > 0) {
            // Simple case: collect identifier and value
            // e.g., max_depth(50) → "max_depth(50)"
            let first = int_to_ptr(get_at(attr_tokens, 0));
            let attr_str = first;

            // If we have more tokens (e.g., "50"), append them
            if (array_len(attr_tokens) > 1) {
                let second = int_to_ptr(get_at(attr_tokens, 1));
                attr_str = concat(attr_str, "(");
                attr_str = concat(attr_str, second);
                attr_str = concat(attr_str, ")");
            }

            attributes = push(attributes, ptr_to_int(attr_str));
        }
    }

    let result = [0, 0];
    result = set_at(result, 0, ptr_to_int(attributes));
    result = set_at(result, 1, ptr_to_int(state));
    return result;
}

fn parse_function(state: [i64]) -> [i64] {
    // Parse attributes before function keyword
    let attr_result = parse_attributes(state);
    let attributes = int_to_ptr(get_at(attr_result, 0));
    state = int_to_ptr(get_at(attr_result, 1));

    state = expect(state, TOK_FN());
    state = expect(state, TOK_IDENT());

    // Get function name from previous token
    let tokens = parser_tokens(state);
    let pos = parser_pos(state) - 1;
    let name_tok = get_at(tokens, pos);
    let name = int_to_ptr(get_at(name_tok, 1));

    state = expect(state, TOK_LPAREN());

    // Parse parameters
    let params = [];
    loop(peek_kind(state) != TOK_RPAREN(), 100) {
        if peek_kind(state) == TOK_RPAREN() { break; }

        state = expect(state, TOK_IDENT());
        let param_pos = parser_pos(state) - 1;
        let param_tok = get_at(tokens, param_pos);
        let param_name = get_at(param_tok, 1);
        params = push(params, param_name);

        // Optional type annotation: : i64
        if peek_kind(state) == TOK_COLON() {
            state = advance(state);  // Skip colon
            state = expect(state, TOK_IDENT());  // Skip type name (we ignore types for now)
        }

        if peek_kind(state) == TOK_COMMA() {
            state = advance(state);
        }
    }

    state = expect(state, TOK_RPAREN());

    // Optional return type (skip for now)
    if peek_kind(state) == TOK_ARROW() {
        state = advance(state);
        state = expect(state, TOK_IDENT());  // Skip type name
    }

    state = expect(state, TOK_LBRACE());

    // Parse body
    let body = [];
    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        let stmt_result = parse_statement(state);
        let stmt = get_at(stmt_result, 0);
        state = int_to_ptr(get_at(stmt_result, 1));
        body = push(body, stmt);
    }

    state = expect(state, TOK_RBRACE());

    let func = make_function(name, params, body, attributes);
    let ret = [0, 0];
    ret = set_at(ret, 0, ptr_to_int(func));
    ret = set_at(ret, 1, ptr_to_int(state));
    return ret;
}

export fn parse_program(tokens: [i64]) -> [i64] {
    let state = make_parser(tokens);

    // Accept "program" or "module" keyword
    let kind = peek_kind(state);
    if kind == TOK_PROGRAM() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
    } else if kind == TOK_MODULE() {
        state = advance(state);
        state = expect(state, TOK_IDENT());
    } else {
        print("Error: expected 'program' or 'module'\n");
    }
    
    state = expect(state, TOK_LBRACE());

    // Parse top-level items: functions, agents, clusters
    let functions = [];
    let agents = [];
    let clusters = [];
    
    loop(peek_kind(state) != TOK_RBRACE(), 1000) {
        if peek_kind(state) == TOK_RBRACE() { break; }
        if peek_kind(state) == TOK_EOF() { break; }

        let item_kind = peek_kind(state);
        
        // Recursive agent at top level
        if item_kind == TOK_RECURSIVE() {
            let agent_result = parse_agent_def(state);
            let agent = get_at(agent_result, 0);
            state = int_to_ptr(get_at(agent_result, 1));
            agents = push(agents, agent);
        }
        // Scale cluster at top level
        else if item_kind == TOK_SCALE() {
            let cluster_result = parse_cluster_def(state);
            let cluster = get_at(cluster_result, 0);
            state = int_to_ptr(get_at(cluster_result, 1));
            clusters = push(clusters, cluster);
        }
        // Dissolvable agent at top level
        else if item_kind == TOK_DISSOLVABLE() {
            let dissolvable_result = parse_dissolvable_agent(state);
            let d = get_at(dissolvable_result, 0);
            state = int_to_ptr(get_at(dissolvable_result, 1));
            agents = push(agents, d);
        }
        // Function or export
        else if item_kind == TOK_FN() || item_kind == TOK_EXPORT() {
            let func_result = parse_function(state);
            let func = get_at(func_result, 0);
            state = int_to_ptr(get_at(func_result, 1));
            functions = push(functions, func);
        }
        // Import statement
        else if item_kind == TOK_IMPORT() {
            let stmt_result = parse_statement(state);
            state = int_to_ptr(get_at(stmt_result, 1));
        }
        // Unknown - skip
        else {
            state = advance(state);
        }
    }

    state = expect(state, TOK_RBRACE());

    return make_program(functions);
}

