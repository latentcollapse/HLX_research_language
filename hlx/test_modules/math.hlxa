// Simple math module with exported functions

module math_lib {
    export fn add(a: i64, b: i64) -> i64 {
        return a + b;
    }

    export fn multiply(a: i64, b: i64) -> i64 {
        return a * b;
    }

    // Private helper function (not exported)
    fn internal_double(x: i64) -> i64 {
        return x * 2;
    }
}
