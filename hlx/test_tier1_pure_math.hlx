// Test suite for Tier 1 Pure Math Operations
// Phase 3 of builtin library conversion

program test_tier1_pure_math {

    // ========================================================================
    // TIER 1 PURE MATH FUNCTIONS (Embedded from tier1_pure_math module)
    // ========================================================================

    fn abs(x: i64) -> i64 {
        if (x < 0) {
            return 0 - x;
        }
        return x;
    }

    fn min(a: i64, b: i64) -> i64 {
        if (a < b) {
            return a;
        }
        return b;
    }

    fn max(a: i64, b: i64) -> i64 {
        if (a > b) {
            return a;
        }
        return b;
    }

    fn clamp(v: i64, min_val: i64, max_val: i64) -> i64 {
        if (v < min_val) {
            return min_val;
        }
        if (v > max_val) {
            return max_val;
        }
        return v;
    }

    fn sign(x: i64) -> i64 {
        if (x < 0) {
            return 0 - 1;
        }
        if (x > 0) {
            return 1;
        }
        return 0;
    }

    fn lerp(a: i64, b: i64, t: i64) -> i64 {
        // Integer lerp: a + (b-a)*t/100
        // Special cases to avoid float division issues
        if (t == 0) {
            return a;
        }
        if (t == 100) {
            return b;
        }

        // General case: compute with proper truncation
        let diff = b - a;
        let scaled = diff * t;

        // Integer divide with proper truncation handling
        let numerator = scaled;
        let denominator = 100;

        // Use simple long division approach
        let quotient = 0;
        let remainder = numerator;

        loop(remainder >= denominator, 100) {
            remainder = remainder - denominator;
            quotient = quotient + 1;
        }

        return a + quotient;
    }

    fn gcd(a: i64, b: i64) -> i64 {
        let x = a;
        let y = b;
        if (x < 0) {
            x = 0 - x;
        }
        if (y < 0) {
            y = 0 - y;
        }

        loop(y != 0, 30) {
            let temp = y;
            y = x % y;
            x = temp;
        }

        return x;
    }

    fn lcm(a: i64, b: i64) -> i64 {
        let g = gcd(a, b);

        if (g == 0) {
            return 0;
        }

        let product = a * b;
        if (product < 0) {
            product = 0 - product;
        }

        // Integer divide using long division
        let numerator = product;
        let denominator = g;
        let quotient = 0;
        let remainder = numerator;

        loop(remainder >= denominator, 100) {
            remainder = remainder - denominator;
            quotient = quotient + 1;
        }

        return quotient;
    }

    // ========================================================================
    // TEST SUITE FOR abs() FUNCTION
    // ========================================================================

    fn test_abs_negative() -> i64 {
        let result = abs(0 - 5);
        if (result == 5) {
            return 1;
        }
        return 0;
    }

    fn test_abs_positive() -> i64 {
        let result = abs(5);
        if (result == 5) {
            return 1;
        }
        return 0;
    }

    fn test_abs_zero() -> i64 {
        let result = abs(0);
        if (result == 0) {
            return 1;
        }
        return 0;
    }

    fn test_abs_large_negative() -> i64 {
        let result = abs(0 - 999);
        if (result == 999) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR min() FUNCTION
    // ========================================================================

    fn test_min_first_smaller() -> i64 {
        let result = min(3, 7);
        if (result == 3) {
            return 1;
        }
        return 0;
    }

    fn test_min_second_smaller() -> i64 {
        let result = min(10, 2);
        if (result == 2) {
            return 1;
        }
        return 0;
    }

    fn test_min_equal() -> i64 {
        let result = min(5, 5);
        if (result == 5) {
            return 1;
        }
        return 0;
    }

    fn test_min_negative() -> i64 {
        let result = min(0 - 5, 2);
        if (result == 0 - 5) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR max() FUNCTION
    // ========================================================================

    fn test_max_first_larger() -> i64 {
        let result = max(10, 3);
        if (result == 10) {
            return 1;
        }
        return 0;
    }

    fn test_max_second_larger() -> i64 {
        let result = max(4, 8);
        if (result == 8) {
            return 1;
        }
        return 0;
    }

    fn test_max_equal() -> i64 {
        let result = max(5, 5);
        if (result == 5) {
            return 1;
        }
        return 0;
    }

    fn test_max_negative() -> i64 {
        let result = max(0 - 10, 0 - 3);
        if (result == 0 - 3) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR clamp() FUNCTION
    // ========================================================================

    fn test_clamp_in_range() -> i64 {
        let result = clamp(5, 1, 10);
        if (result == 5) {
            return 1;
        }
        return 0;
    }

    fn test_clamp_below_min() -> i64 {
        let result = clamp(0 - 5, 0, 10);
        if (result == 0) {
            return 1;
        }
        return 0;
    }

    fn test_clamp_above_max() -> i64 {
        let result = clamp(15, 0, 10);
        if (result == 10) {
            return 1;
        }
        return 0;
    }

    fn test_clamp_at_boundaries() -> i64 {
        let result1 = clamp(1, 1, 10);
        let result2 = clamp(10, 1, 10);
        if (result1 == 1) {
            if (result2 == 10) {
                return 1;
            }
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR sign() FUNCTION
    // ========================================================================

    fn test_sign_negative() -> i64 {
        let result = sign(0 - 42);
        if (result == 0 - 1) {
            return 1;
        }
        return 0;
    }

    fn test_sign_positive() -> i64 {
        let result = sign(42);
        if (result == 1) {
            return 1;
        }
        return 0;
    }

    fn test_sign_zero() -> i64 {
        let result = sign(0);
        if (result == 0) {
            return 1;
        }
        return 0;
    }

    fn test_sign_negative_one() -> i64 {
        let result = sign(0 - 1);
        if (result == 0 - 1) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR lerp() FUNCTION
    // ========================================================================

    fn test_lerp_midpoint() -> i64 {
        let result = lerp(0, 100, 50);
        if (result == 50) {
            return 1;
        }
        return 0;
