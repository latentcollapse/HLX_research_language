        if (result == 4) {
            return 1;
        }
        return 0;
    }

    fn test_gcd_coprime() -> i64 {
        let result = gcd(7, 13);
        if (result == 1) {
            return 1;
        }
        return 0;
    }

    fn test_gcd_same_number() -> i64 {
        let result = gcd(15, 15);
        if (result == 15) {
            return 1;
        }
        return 0;
    }

    fn test_gcd_with_negative() -> i64 {
        let result = gcd(0 - 12, 8);
        if (result == 4) {
            return 1;
        }
        return 0;
    }

    // ========================================================================
    // TEST SUITE FOR lcm() FUNCTION
    // ========================================================================

    fn test_lcm_common_multiple() -> i64 {
        let result = lcm(4, 6);
        if (result == 12) {
            return 1;
        }
        return 0;
    }

    fn test_lcm_coprime() -> i64 {
        let result = lcm(3, 5);
        if (result == 15) {
            return 1;
        }
        return 0;
    }

    fn test_lcm_same_number() -> i64 {
        let result = lcm(7, 7);
        if (result == 7) {
            return 1;
        }
        return 0;
    }

    fn test_lcm_larger_values() -> i64 {
        let result = lcm(12, 8);
        if (result == 24) {
            return 1;
        }
        return 0;
    }

