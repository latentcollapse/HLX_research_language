# HLX Docker Environment Variables
# Copy this file to .env and customize as needed

# HLX Runtime Backend
HLX_BACKEND=cpu
# Options: cpu, vulkan, cuda, metal

# Logging Level
HLX_LOG_LEVEL=info
# Options: trace, debug, info, warn, error

# LSP Server Port (for TCP mode)
HLX_LSP_PORT=9257

# LLVM Configuration
LLVM_SYS_180_PREFIX=/usr/lib/llvm-18

# Workspace Directory (mounted into container)
HLX_WORKSPACE=./examples

# Output Directory
HLX_OUTPUT=./output

# Docker User ID (match your host user for file permissions)
HLX_UID=1000
HLX_GID=1000
