program advanced_lsp_test {
    fn main() {
        // TEST 1: Snippet Expansion
        // Type @ here and select a contract - it will auto-fill all fields!
        // Try @906 - you'll get: @906 { A: $1, B: $2 }$0


        // TEST 2: Context-Aware Filtering
        // Type @ in different contexts to see smart filtering:

        // Math context - should show mostly @200-299 (math operations)
        let sum = 5 + 10;
        let result = @   // <-- Type here, you'll see math contracts prioritized

        // Value assignment context - shows types + operations
        let x = @   // <-- Type here, you'll see value-producing contracts

        // Control flow context - shows @500-599 (if/loop/etc)
        if (condition) {
            @   // <-- Type here, you'll see control flow contracts
        }

        // I/O context - shows @600-699 (print/http/etc)
        print("test");
        @   // <-- Type here, you'll see I/O contracts


        // TEST 3: Signature Validation with Errors
        // These should show RED SQUIGGLES for wrong fields:

        // ERROR: 'C' is not a valid field for @906 (should be 'A' and 'B')
        let bad_gemm = @906 { A: matrix_a, C: wrong_field };

        // ERROR: Missing required field 'rhs' for @200 (Add)
        let incomplete_add = @200 { lhs: 5 };

        // ERROR: Unknown field 'wrong' for @16 (String)
        let bad_string = @16 { wrong: "test" };


        // TEST 3: Valid contracts (no errors)
        let good_gemm = @906 { A: matrix_a, B: matrix_b };  // ✓ Correct
        let good_add = @200 { lhs: 5, rhs: 10 };             // ✓ Correct
        let good_string = @16 { @0: "hello" };               // ✓ Correct


        // TEST 4: Hover Documentation
        // Hover over any @ID to see full docs with:
        // - Signature
        // - Field specifications
        // - Examples
        // - Performance notes (for GPU ops)
        // - Related contracts

        let tensor_op = @906 { A: matrix_a, B: matrix_b };  // Hover @906
        let math = @202 { lhs: 3, rhs: 4 };                  // Hover @202
        let str_concat = @300 { lhs: "hello", rhs: "world" };  // Hover @300
    }
}
