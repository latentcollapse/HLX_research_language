// Test HLX string and array operations (Phase 3)
program test_strings_arrays {
    fn main() {
        print("=== Testing String Operations ===");

        // String concatenation
        let s1 = "Hello, ";
        let s2 = "World!";
        let s3 = concat(s1, s2);
        print("concat:");
        print(s3);  // "Hello, World!"

        // String length
        let len = strlen(s3);
        print("strlen:");
        print(len);  // 13

        // Substring
        let sub = substring(s3, 0, 5);
        print("substring:");
        print(sub);  // "Hello"

        // Index of
        let idx = index_of(s3, "World");
        print("index_of:");
        print(idx);  // 7

        // Replace
        let replaced = replace(s3, "World", "HLX");
        print("replace:");
        print(replaced);  // "Hello, HLX!"

        // Split
        let parts = split("apple,banana,cherry", ",");
        print("split:");
        print(parts);  // ["apple", "banana", "cherry"]

        // Join
        let joined = join(parts, " | ");
        print("join:");
        print(joined);  // "apple | banana | cherry"

        // To upper/lower
        let upper = to_upper("hello");
        let lower = to_lower("WORLD");
        print("to_upper:");
        print(upper);  // "HELLO"
        print("to_lower:");
        print(lower);  // "world"

        // Trim
        let trimmed = trim("  spaces  ");
        print("trim:");
        print(trimmed);  // "spaces"

        // Starts with / ends with
        let sw = starts_with("hello world", "hello");
        let ew = ends_with("hello world", "world");
        print("starts_with:");
        print(sw);  // true
        print("ends_with:");
        print(ew);  // true

        // Repeat
        let repeated = repeat("Ha", 3);
        print("repeat:");
        print(repeated);  // "HaHaHa"

        // Reverse
        let reversed = str_reverse("hello");
        print("str_reverse:");
        print(reversed);  // "olleh"

        // Char at
        let ch = char_at("hello", 1);
        print("char_at:");
        print(ch);  // "e"

        print("=== Testing Array Operations ===");

        // Array push
        let arr1 = [1, 2, 3];
        let arr2 = push(arr1, 4);
        print("push:");
        print(arr2);  // [1, 2, 3, 4]

        // Array unshift
        let arr3 = unshift(arr2, 0);
        print("unshift:");
        print(arr3);  // [0, 1, 2, 3, 4]

        // Array slice
        let sliced = slice(arr3, 1, 3);
        print("slice:");
        print(sliced);  // [1, 2, 3]

        // Array concat
        let arr4 = [5, 6];
        let concatenated = arr_concat(arr2, arr4);
        print("arr_concat:");
        print(concatenated);  // [1, 2, 3, 4, 5, 6]

        // Array reverse
        let rev = reverse(arr2);
        print("reverse:");
        print(rev);  // [4, 3, 2, 1]

        // Array sort
        let unsorted = [3, 1, 4, 1, 5, 9, 2, 6];
        let sorted = sort(unsorted);
        print("sort:");
        print(sorted);  // [1, 1, 2, 3, 4, 5, 6, 9]

        // Array find
        let found = find(arr2, 3);
        print("find:");
        print(found);  // 2 (index of element 3)

        let not_found = find(arr2, 99);
        print("find (not found):");
        print(not_found);  // -1

        print("=== All tests complete! ===");

        return 0;
    }
}
