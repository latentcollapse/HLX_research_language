// Test all bootstrap compiler builtins

program test_builtins {

fn main() -> i64 {
    print("=== Testing Bootstrap Builtins ===\n");

    // Test 1: push and array_len
    print("\nTest 1: push and array_len\n");
    let arr = [];
    arr = push(arr, 10);
    arr = push(arr, 20);
    arr = push(arr, 30);
    let len = array_len(arr);
    print("Array length: ");
    print(len);
    print("\n");

    // Test 2: get_at
    print("\nTest 2: get_at\n");
    let val = get_at(arr, 1);
    print("arr[1] = ");
    print(val);
    print("\n");

    // Test 3: set_at
    print("\nTest 3: set_at\n");
    arr = set_at(arr, 1, 99);
    val = get_at(arr, 1);
    print("After set_at(arr, 1, 99): arr[1] = ");
    print(val);
    print("\n");

    // Test 4: char_code
    print("\nTest 4: char_code\n");
    let code = char_code("A");
    print("char_code('A') = ");
    print(code);
    print(" (should be 65)\n");

    // Test 5: is_digit
    print("\nTest 5: is_digit\n");
    let is_d1 = is_digit("5");
    let is_d2 = is_digit("a");
    print("is_digit('5') = ");
    print(is_d1);
    print("\n");
    print("is_digit('a') = ");
    print(is_d2);
    print("\n");

    // Test 6: is_whitespace
    print("\nTest 6: is_whitespace\n");
    let is_ws1 = is_whitespace(" ");
    let is_ws2 = is_whitespace("x");
    print("is_whitespace(' ') = ");
    print(is_ws1);
    print("\n");
    print("is_whitespace('x') = ");
    print(is_ws2);
    print("\n");

    // Test 7: strcmp
    print("\nTest 7: strcmp\n");
    let cmp1 = strcmp("abc", "abc");
    let cmp2 = strcmp("abc", "xyz");
    let cmp3 = strcmp("xyz", "abc");
    print("strcmp('abc', 'abc') = ");
    print(cmp1);
    print(" (should be 0)\n");
    print("strcmp('abc', 'xyz') = ");
    print(cmp2);
    print(" (should be -1)\n");
    print("strcmp('xyz', 'abc') = ");
    print(cmp3);
    print(" (should be 1)\n");

    // Test 8: ptr_to_int / int_to_ptr (identity functions)
    print("\nTest 8: ptr_to_int / int_to_ptr\n");
    let ptr = ptr_to_int(arr);
    let restored = int_to_ptr(ptr);
    let restored_len = array_len(restored);
    print("Pointer round-trip: array_len(int_to_ptr(ptr_to_int(arr))) = ");
    print(restored_len);
    print("\n");

    print("\n=== ALL BUILTINS WORKING! ===\n");
    return 0;
}

}
