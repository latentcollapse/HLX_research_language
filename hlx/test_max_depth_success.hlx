// Test successful recursion with appropriate max_depth limits

program test_max_depth_success {

    // Test 1: Adequate max_depth - should succeed
    #[max_depth(10)]
    fn countdown_10(n) {
        if (n <= 0) { return 0; }
        return 1 + countdown_10(n - 1);
    }

    // Test 2: Generous max_depth - should succeed
    #[max_depth(50)]
    fn countdown_50(n) {
        if (n <= 0) { return 0; }
        return 1 + countdown_50(n - 1);
    }

    // Test 3: Edge - exactly enough max_depth
    #[max_depth(6)]
    fn countdown_exact(n) {
        if (n <= 0) { return 0; }
        return 1 + countdown_exact(n - 1);
    }

    fn main() -> i64 {
        print("Testing max_depth with successful recursion\n");
        print("==========================================\n\n");

        print("Test 1: countdown_10(5) with max_depth(10)\n");
        let result1 = countdown_10(5);
        print("Result: ");
        print(result1);
        print(" (expected: 5)\n\n");

        print("Test 2: countdown_50(20) with max_depth(50)\n");
        let result2 = countdown_50(20);
        print("Result: ");
        print(result2);
        print(" (expected: 20)\n\n");

        print("Test 3: countdown_exact(5) with max_depth(6)\n");
        let result3 = countdown_exact(5);
        print("Result: ");
        print(result3);
        print(" (expected: 5)\n\n");

        print("✓ All max_depth success tests passed!\n");
        return 1;
    }
}
