{
  "name": "hlx-language",
  "displayName": "HLX Language Support",
  "description": "Language support for HLX (Helix Language)",
  "version": "0.1.0",
  "publisher": "latentcollapse",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:hlx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [{
      "id": "hlx",
      "aliases": ["HLX", "hlx"],
      "extensions": [".hlxa", ".hlxc"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "hlx",
      "scopeName": "source.hlx",
      "path": "./syntaxes/hlx.tmLanguage.json"
    }],
    "configuration": {
      "type": "object",
      "title": "HLX Language Server",
      "properties": {
        "hlx.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to hlx_lsp binary (leave empty to use bundled)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
