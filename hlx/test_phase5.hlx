// Comprehensive Phase 5 test: Parsing and File I/O Operations
program test_phase5 {
    fn main() {
        print("=== Phase 5: Parsing & File I/O Test ===");
        print("");

        // ======= Parsing Operations =======
        print("--- Parsing Operations ---");

        // Parse integer
        let num_str = "42";
        let num = parse_int(num_str);
        print("parse_int('42'):");
        print(num);  // 42

        // Parse float
        let float_str = "3.14159";
        let pi = parse_float(float_str);
        print("parse_float('3.14159'):");
        print(pi);  // 3.14159

        // JSON serialize
        let val = 123;
        let json = json_serialize(val);
        print("json_serialize(123):");
        print(json);  // "123"

        let str_val = "hello";
        let json_str = json_serialize(str_val);
        print("json_serialize('hello'):");
        print(json_str);  // "\"hello\""

        // CSV parse
        let csv = "alice,30,engineer";
        let row = csv_parse(csv, ",");
        print("csv_parse('alice,30,engineer', ','):");
        print(row);  // [["alice", "30", "engineer"]]

        // Format string
        let name = "World";
        let num2 = 2026;
        let formatted = format("Hello {} in {}", name, num2);
        print("format('Hello {} in {}', 'World', 2026):");
        print(formatted);  // "Hello World in 2026"

        // Regex match (simple contains for now)
        let text = "Hello World";
        let pattern = "World";
        let matches = regex_match(text, pattern);
        print("regex_match('Hello World', 'World'):");
        print(matches);  // ["World"]

        // Regex replace
        let replaced = regex_replace("Hello World", "World", "HLX");
        print("regex_replace('Hello World', 'World', 'HLX'):");
        print(replaced);  // "Hello HLX"

        print("");

        // ======= File I/O Operations =======
        print("--- File I/O Operations ---");

        // Create directory
        let dir_created = create_dir("test_output");
        print("create_dir('test_output'):");
        print(dir_created);  // true

        // File exists check
        let exists_before = file_exists("test_output/test.txt");
        print("file_exists('test_output/test.txt') before:");
        print(exists_before);  // false

        // Write JSON
        let json_success = write_json("test_output/data.json", "Hello JSON");
        print("write_json('test_output/data.json', 'Hello JSON'):");
        print(json_success);  // true

        // Read JSON
        let json_content = read_json("test_output/data.json");
        print("read_json('test_output/data.json'):");
        print(json_content);  // "Hello JSON"

        // Append to file
        let append1 = append_file("test_output/test.txt", "Line 1\n");
        let append2 = append_file("test_output/test.txt", "Line 2\n");
        print("append_file x2:");
        print(append1);  // true
        print(append2);  // true

        // File exists check after creation
        let exists_after = file_exists("test_output/test.txt");
        print("file_exists('test_output/test.txt') after:");
        print(exists_after);  // true

        // Write CSV
        let csv_data = [["name", "age"], ["Alice", "30"], ["Bob", "25"]];
        let csv_success = write_csv("test_output/data.csv", csv_data, ",");
        print("write_csv('test_output/data.csv', ...):");
        print(csv_success);  // true

        // Read CSV
        let csv_result = read_csv("test_output/data.csv", ",");
        print("read_csv('test_output/data.csv', ','):");
        print(csv_result);  // [["name", "age"], ["Alice", "30"], ["Bob", "25"]]

        // List files in directory
        let files = list_files("test_output");
        print("list_files('test_output'):");
        print(files);  // ["test.txt", "data.json", "data.csv"]

        // Delete file
        let deleted = delete_file("test_output/test.txt");
        print("delete_file('test_output/test.txt'):");
        print(deleted);  // true

        // Note: Not deleting directory to preserve test files
        // let dir_deleted = delete_dir("test_output");

        print("");
        print("=== All Phase 5 operations working! ===");

        return 0;
    }
}
