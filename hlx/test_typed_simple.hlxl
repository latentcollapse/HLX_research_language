// Simple typed array test

program test_typed_simple {

block main() {
    // Create a typed float array
    let floats: Array<Float> = alloc_array(2);

    // Store float values
    floats[0] = 3.14;
    floats[1] = 2.71;

    // Load and use them - this should work without bitcast!
    let a = floats[0];
    let b = floats[1];
    let result = a * b;  // Should be 3.14 * 2.71 = 8.5094

    // Also test that we can create an array with literal syntax
    let nums: Array<Float> = [1.0, 2.0, 3.0];
    let first = nums[0];

    print_str("Typed arrays work!");
    return 0;
}

}
