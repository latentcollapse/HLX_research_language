// Comprehensive Phase 3 test: String and Array Operations
program test_phase3 {
    fn main() {
        print("=== Phase 3: String & Array Operations Test ===");
        print("");

        // ======= String Operations =======
        print("--- String Operations ---");

        let msg = concat("Hello", " World");
        print(msg);  // "Hello World"

        let length = strlen(msg);
        print(length);  // 11

        let sub1 = substring(msg, 0, 5);
        print(sub1);  // "Hello"

        let pos = index_of(msg, "World");
        print(pos);  // 6

        let replaced = replace(msg, "World", "HLX");
        print(replaced);  // "Hello HLX"

        let tokens = split("a,b,c", ",");
        print(tokens);  // ["a", "b", "c"]

        let joined = join(tokens, "-");
        print(joined);  // "a-b-c"

        print(to_upper("hello"));  // "HELLO"
        print(to_lower("WORLD"));  // "world"
        print(trim("  space  "));  // "space"

        print(starts_with("hello", "hel"));  // true
        print(ends_with("world", "rld"));  // true

        let repeated = repeat("Hi", 3);
        print(repeated);  // "HiHiHi"

        let reversed_str = str_reverse("abc");
        print(reversed_str);  // "cba"

        let ch = char_at("hello", 1);
        print(ch);  // "e"

        print("");

        // ======= Array Operations =======
        print("--- Array Operations ---");

        let nums = [1, 2, 3];
        print(nums);

        let nums2 = push(nums, 4);
        print(nums2);  // [1, 2, 3, 4]

        let nums3 = unshift(nums2, 0);
        print(nums3);  // [0, 1, 2, 3, 4]

        let sliced_arr = slice(nums3, 1, 3);
        print(sliced_arr);  // [1, 2, 3]

        let more = [5, 6];
        let combined = arr_concat(nums2, more);
        print(combined);  // [1, 2, 3, 4, 5, 6]

        let reversed_arr = reverse(nums2);
        print(reversed_arr);  // [4, 3, 2, 1]

        let unsorted = [5, 2, 8, 1, 9];
        let sorted_arr = sort(unsorted);
        print(sorted_arr);  // [1, 2, 5, 8, 9]

        let search_idx = find(nums2, 3);
        print(search_idx);  // 2

        let missing = find(nums2, 100);
        print(missing);  // -1

        print("");
        print("=== All Phase 3 operations working! ===");

        return 0;
    }
}
