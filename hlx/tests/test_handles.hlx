// ═══════════════════════════════════════════════════════════════════════════
// HLX Handle Operations Tests
// Tests for collapse/resolve reversibility and handle semantics
// ═══════════════════════════════════════════════════════════════════════════

module test_handles {

    // Test 1: Simple collapse and resolve
    fn test_collapse_resolve_simple() {
        let value = 42;
        let handle = collapse(value);
        let recovered = resolve(handle);

        if (recovered == 42) {
            print("PASS: test_collapse_resolve_simple\n");
            return 1;
        }
        print("FAIL: test_collapse_resolve_simple\n");
        return 0;
    }

    // Test 2: Collapse resolve with contract
    fn test_handle_with_contract() {
        let data = {1:{@0:100, @1:200}};
        let handle = collapse(data);
        let recovered = recover_handle(handle);

        // We can't directly compare contracts yet, so test field access
        let field_value = recovered.@0;

        if (field_value == 100) {
            print("PASS: test_handle_with_contract\n");
            return 1;
        }
        print("FAIL: test_handle_with_contract\n");
        return 0;
    }

    // Helper function to work around resolve - collapse bijection
    fn recover_handle(handle: i64) -> [i64] {
        let dummy = {1:{@0:0, @1:0}};
        return resolve(handle);
    }

    // Test 3: Multiple independent handles
    fn test_multiple_handles() {
        let h1 = collapse(10);
        let h2 = collapse(20);
        let h3 = collapse(30);

        let v1 = resolve(h1);
        let v2 = resolve(h2);
        let v3 = resolve(h3);

        if (v1 == 10) {
            if (v2 == 20) {
                if (v3 == 30) {
                    print("PASS: test_multiple_handles\n");
                    return 1;
                }
            }
        }
        print("FAIL: test_multiple_handles\n");
        return 0;
    }

    // Test 4: Handle reuse pattern
    fn test_handle_reuse() {
        let h = collapse(50);
        let v1 = resolve(h);
        let v2 = resolve(h);

        if (v1 == 50) {
            if (v2 == 50) {
                print("PASS: test_handle_reuse\n");
                return 1;
            }
        }
        print("FAIL: test_handle_reuse\n");
        return 0;
    }

    // Test 5: Handle in arithmetic
    fn test_handle_in_arithmetic() {
        let h = collapse(15);
        let v = resolve(h);
        let result = v + 10;

        if (result == 25) {
            print("PASS: test_handle_in_arithmetic\n");
            return 1;
        }
        print("FAIL: test_handle_in_arithmetic\n");
        return 0;
    }

    // Test 6: Nested collapse (handle of a handle ID)
    fn test_nested_handles() {
        let h1 = collapse(100);
        let h2 = collapse(h1);  // Handle ID itself becomes value
        let recovered_h1 = resolve(h2);

        if (recovered_h1 == h1) {
            let final_value = resolve(recovered_h1);
            if (final_value == 100) {
                print("PASS: test_nested_handles\n");
                return 1;
            }
        }
        print("FAIL: test_nested_handles\n");
        return 0;
    }

    // Test 7: Handle in loop
    fn test_handle_in_loop() {
        let h = collapse(5);
        let max = resolve(h);
        let sum = 0;

        loop(sum < max, 10) {
            sum = sum + 1;
        }

        if (sum == 5) {
            print("PASS: test_handle_in_loop\n");
            return 1;
        }
        print("FAIL: test_handle_in_loop\n");
        return 0;
    }

    // Test 8: Handle bijection - collapse then resolve should equal identity
    fn test_handle_bijection() {
        let original = 777;
        let handle = collapse(original);
        let final_value = resolve(handle);

        // Bijection: collapse(x) then resolve(collapse(x)) == x
        if (final_value == original) {
            print("PASS: test_handle_bijection\n");
            return 1;
        }
        print("FAIL: test_handle_bijection\n");
        return 0;
    }

    // Test 9: Handle comparison
    fn test_handle_comparison() {
        let h1 = collapse(123);
        let h2 = collapse(123);

        // Different handles even though values are same
        if (h1 != h2) {
            print("PASS: test_handle_comparison\n");
            return 1;
        }
        print("FAIL: test_handle_comparison\n");
        return 0;
    }

    // Test 10: Complex handle scenario
    fn test_complex_handles() {
        let configs = [{1:{@0:10, @1:20}}, {1:{@0:30, @1:40}}];
        let h1 = collapse(configs[0]);
        let h2 = collapse(configs[1]);

        let recovered1 = resolve(h1);
        let recovered2 = resolve(h2);

        let v1 = recovered1.@0;
        let v2 = recovered2.@0;

        if (v1 == 10) {
            if (v2 == 30) {
                print("PASS: test_complex_handles\n");
                return 1;
            }
        }
        print("FAIL: test_complex_handles\n");
        return 0;
    }

    // Main test runner
    fn main() -> i64 {
        print("═══════════════════════════════════════════════════════\n");
        print("HLX Handle Operations Tests\n");
        print("═══════════════════════════════════════════════════════\n");
        print("\n");

        let passed = 0;
        let failed = 0;

        if (test_collapse_resolve_simple() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_handle_with_contract() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_multiple_handles() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_handle_reuse() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_handle_in_arithmetic() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_nested_handles() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_handle_in_loop() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_handle_bijection() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_handle_comparison() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_complex_handles() == 1) { passed = passed + 1; } else { failed = failed + 1; }

        print("\n");
        print("═══════════════════════════════════════════════════════\n");
        print("Results: ");
        print_int(passed);
        print(" passed, ");
        print_int(failed);
        print(" failed\n");
        print("═══════════════════════════════════════════════════════\n");

        if (failed == 0) {
            print("\nAll handle tests PASSED!\n");
            return 0;
        } else {
            print("\nSome tests FAILED\n");
            return 1;
        }
    }
}
