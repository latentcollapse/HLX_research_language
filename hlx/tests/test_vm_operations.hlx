// ═══════════════════════════════════════════════════════════════════════════
// HLX VM Operations Tests
// Tests for all instruction handlers in the native runtime
// ═══════════════════════════════════════════════════════════════════════════

module test_vm_operations {

    // Test 1: Arithmetic operations
    fn test_arithmetic() {
        let a = 20;
        let b = 5;

        let add_result = a + b;       // 25
        let sub_result = a - b;       // 15
        let mul_result = a * b;       // 100
        let div_result = a / b;       // 4
        let mod_result = a % b;       // 0

        if (add_result == 25) {
            if (sub_result == 15) {
                if (mul_result == 100) {
                    if (div_result == 4) {
                        if (mod_result == 0) {
                            print("PASS: test_arithmetic\n");
                            return 1;
                        }
                    }
                }
            }
        }
        print("FAIL: test_arithmetic\n");
        return 0;
    }

    // Test 2: Comparison operations
    fn test_comparisons() {
        let x = 10;
        let y = 20;

        let eq = if (x == x) { 1; } else { 0; };
        let ne = if (x != y) { 1; } else { 0; };
        let lt = if (x < y) { 1; } else { 0; };
        let le = if (x <= y) { 1; } else { 0; };
        let gt = if (y > x) { 1; } else { 0; };
        let ge = if (y >= x) { 1; } else { 0; };

        if (eq == 1) {
            if (ne == 1) {
                if (lt == 1) {
                    if (le == 1) {
                        if (gt == 1) {
                            if (ge == 1) {
                                print("PASS: test_comparisons\n");
                                return 1;
                            }
                        }
                    }
                }
            }
        }
        print("FAIL: test_comparisons\n");
        return 0;
    }

    // Test 3: Logical operations
    fn test_logical() {
        let t = 1;
        let f = 0;

        let and_result = if (t && t) { 1; } else { 0; };
        let or_result = if (t || f) { 1; } else { 0; };
        let not_result = if (!f) { 1; } else { 0; };

        if (and_result == 1) {
            if (or_result == 1) {
                if (not_result == 1) {
                    print("PASS: test_logical\n");
                    return 1;
                }
            }
        }
        print("FAIL: test_logical\n");
        return 0;
    }

    // Test 4: Bitwise operations
    fn test_bitwise() {
        let a = 12;  // 1100 in binary
        let b = 10;  // 1010 in binary

        let and_result = bit_and(a, b);      // 1000 = 8
        let or_result = bit_or(a, b);        // 1110 = 14
        let xor_result = bit_xor(a, b);      // 0110 = 6
        let shl_result = bit_shl(a, 1);      // 11000 = 24
        let shr_result = bit_shr(a, 1);      // 0110 = 6

        if (and_result == 8) {
            if (or_result == 14) {
                if (xor_result == 6) {
                    if (shl_result == 24) {
                        if (shr_result == 6) {
                            print("PASS: test_bitwise\n");
                            return 1;
                        }
                    }
                }
            }
        }
        print("FAIL: test_bitwise\n");
        return 0;
    }

    // Test 5: Control flow - if/else
    fn test_control_flow_if() {
        let result = 0;

        if (5 > 3) {
            result = 1;
        } else {
            result = 0;
        }

        if (result == 1) {
            print("PASS: test_control_flow_if\n");
            return 1;
        }
        print("FAIL: test_control_flow_if\n");
        return 0;
    }

    // Test 6: Loops
    fn test_loops() {
        let sum = 0;
        let i = 0;

        loop(i < 5, 10) {
            sum = sum + i;
            i = i + 1;
        }

        // sum should be 0+1+2+3+4 = 10
        if (sum == 10) {
            print("PASS: test_loops\n");
            return 1;
        }
        print("FAIL: test_loops\n");
        return 0;
    }

    // Test 7: Nested loops
    fn test_nested_loops() {
        let result = 0;
        let i = 0;

        loop(i < 3, 10) {
            let j = 0;
            loop(j < 2, 10) {
                result = result + 1;
                j = j + 1;
            }
            i = i + 1;
        }

        // result should be 3*2 = 6
        if (result == 6) {
            print("PASS: test_nested_loops\n");
            return 1;
        }
        print("FAIL: test_nested_loops\n");
        return 0;
    }

    // Test 8: Complex expression with mixed operations
    fn test_complex_expression() {
        let a = 10;
        let b = 3;
        let c = 2;

        let result = (a + b) * c - (a - b);
        // (10+3)*2 - (10-3) = 13*2 - 7 = 26 - 7 = 19

        if (result == 19) {
            print("PASS: test_complex_expression\n");
            return 1;
        }
        print("FAIL: test_complex_expression\n");
        return 0;
    }

    // Test 9: Division and modulo with edge cases
    fn test_division_edge_cases() {
        let a = 17;
        let b = 5;

        let div = a / b;     // 3
        let mod = a % b;     // 2

        if (div == 3) {
            if (mod == 2) {
                print("PASS: test_division_edge_cases\n");
                return 1;
            }
        }
        print("FAIL: test_division_edge_cases\n");
        return 0;
    }

    // Test 10: All handlers integrated
    fn test_all_handlers_integrated() {
        let x = 100;
        let y = 25;

        let arithmetic = (x + y) * 2 / (y - 20);  // (125*2)/5 = 50
        let compared = if (arithmetic > 40) { 1; } else { 0; };  // 1
        let logical = if (compared && (arithmetic < 60)) { 1; } else { 0; };  // 1
        let bitwise = bit_and(arithmetic, 48);  // 50 & 48 = 48

        if (arithmetic == 50) {
            if (compared == 1) {
                if (logical == 1) {
                    if (bitwise == 48) {
                        print("PASS: test_all_handlers_integrated\n");
                        return 1;
                    }
                }
            }
        }
        print("FAIL: test_all_handlers_integrated\n");
        return 0;
    }

    // Main test runner
    fn main() -> i64 {
        print("═══════════════════════════════════════════════════════\n");
        print("HLX VM Operations Tests\n");
        print("═══════════════════════════════════════════════════════\n");
        print("\n");

        let passed = 0;
        let failed = 0;

        if (test_arithmetic() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_comparisons() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_logical() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_bitwise() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_control_flow_if() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_loops() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_nested_loops() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_complex_expression() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_division_edge_cases() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_all_handlers_integrated() == 1) { passed = passed + 1; } else { failed = failed + 1; }

        print("\n");
        print("═══════════════════════════════════════════════════════\n");
        print("Results: ");
        print_int(passed);
        print(" passed, ");
        print_int(failed);
        print(" failed\n");
        print("═══════════════════════════════════════════════════════\n");

        if (failed == 0) {
            print("\nAll VM operation tests PASSED!\n");
            return 0;
        } else {
            print("\nSome tests FAILED\n");
            return 1;
        }
    }
}
