// ═══════════════════════════════════════════════════════════════════════════
// Fibonacci Benchmark Test
// Tests complex arithmetic, loops, and algorithm correctness
// ═══════════════════════════════════════════════════════════════════════════

module test_fibonacci {

    // Iterative fibonacci - good for testing loops
    fn fib_iterative(n: i64) -> i64 {
        if (n <= 1) {
            return n;
        }

        let a = 0;
        let b = 1;
        let i = 2;

        loop(i <= n, 1000) {
            let temp = a + b;
            a = b;
            b = temp;
            i = i + 1;
        }

        return b;
    }

    // Test: fib(0) = 0
    fn test_fib_zero() {
        let result = fib_iterative(0);
        if (result == 0) {
            print("PASS: test_fib_zero\n");
            return 1;
        }
        print("FAIL: test_fib_zero\n");
        return 0;
    }

    // Test: fib(1) = 1
    fn test_fib_one() {
        let result = fib_iterative(1);
        if (result == 1) {
            print("PASS: test_fib_one\n");
            return 1;
        }
        print("FAIL: test_fib_one\n");
        return 0;
    }

    // Test: fib(5) = 5
    fn test_fib_five() {
        let result = fib_iterative(5);
        if (result == 5) {
            print("PASS: test_fib_five\n");
            return 1;
        }
        print("FAIL: test_fib_five\n");
        return 0;
    }

    // Test: fib(10) = 55
    fn test_fib_ten() {
        let result = fib_iterative(10);
        if (result == 55) {
            print("PASS: test_fib_ten\n");
            return 1;
        }
        print("FAIL: test_fib_ten\n");
        return 0;
    }

    // Test: fib(15) = 610
    fn test_fib_fifteen() {
        let result = fib_iterative(15);
        if (result == 610) {
            print("PASS: test_fib_fifteen\n");
            return 1;
        }
        print("FAIL: test_fib_fifteen\n");
        return 0;
    }

    // Test: fib(20) = 6765
    fn test_fib_twenty() {
        let result = fib_iterative(20);
        if (result == 6765) {
            print("PASS: test_fib_twenty\n");
            return 1;
        }
        print("FAIL: test_fib_twenty\n");
        return 0;
    }

    // Test fibonacci sequence property: fib(n) + fib(n+1) = fib(n+2)
    fn test_fibonacci_property() {
        let f5 = fib_iterative(5);      // 5
        let f6 = fib_iterative(6);      // 8
        let f7 = fib_iterative(7);      // 13

        if (f5 + f6 == f7) {
            print("PASS: test_fibonacci_property\n");
            return 1;
        }
        print("FAIL: test_fibonacci_property\n");
        return 0;
    }

    // Test: monotonically increasing
    fn test_fibonacci_increasing() {
        let f1 = fib_iterative(5);
        let f2 = fib_iterative(10);
        let f3 = fib_iterative(15);

        if (f1 < f2) {
            if (f2 < f3) {
                print("PASS: test_fibonacci_increasing\n");
                return 1;
            }
        }
        print("FAIL: test_fibonacci_increasing\n");
        return 0;
    }

    // Test: even fibonacci numbers
    fn test_even_fibonacci() {
        let f2 = fib_iterative(3);      // 2
        let f4 = fib_iterative(6);      // 8
        let f6 = fib_iterative(9);      // 34

        let is_even_2 = if (f2 % 2 == 0) { 1; } else { 0; };
        let is_even_4 = if (f4 % 2 == 0) { 1; } else { 0; };
        let is_even_6 = if (f6 % 2 == 0) { 1; } else { 0; };

        if (is_even_2 == 1) {
            if (is_even_4 == 1) {
                if (is_even_6 == 1) {
                    print("PASS: test_even_fibonacci\n");
                    return 1;
                }
            }
        }
        print("FAIL: test_even_fibonacci\n");
        return 0;
    }

    // Test: sum of first n fibonacci numbers
    fn sum_first_n_fibonacci(n: i64) -> i64 {
        let sum = 0;
        let i = 0;

        loop(i <= n, 1000) {
            let fib_val = fib_iterative(i);
            sum = sum + fib_val;
            i = i + 1;
        }

        return sum;
    }

    fn test_sum_fibonacci() {
        let sum = sum_first_n_fibonacci(5);
        // fib(0..5) = 0,1,1,2,3,5 = 12
        if (sum == 12) {
            print("PASS: test_sum_fibonacci\n");
            return 1;
        }
        print("FAIL: test_sum_fibonacci\n");
        return 0;
    }

    // Main test runner
    fn main() -> i64 {
        print("═══════════════════════════════════════════════════════\n");
        print("Fibonacci Algorithm Tests\n");
        print("═══════════════════════════════════════════════════════\n");
        print("\n");

        let passed = 0;
        let failed = 0;

        if (test_fib_zero() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_fib_one() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_fib_five() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_fib_ten() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_fib_fifteen() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_fib_twenty() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_fibonacci_property() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_fibonacci_increasing() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_even_fibonacci() == 1) { passed = passed + 1; } else { failed = failed + 1; }
        if (test_sum_fibonacci() == 1) { passed = passed + 1; } else { failed = failed + 1; }

        print("\n");
        print("═══════════════════════════════════════════════════════\n");
        print("Results: ");
        print_int(passed);
        print(" passed, ");
        print_int(failed);
        print(" failed\n");
        print("═══════════════════════════════════════════════════════\n");

        if (failed == 0) {
            print("\nAll Fibonacci tests PASSED!\n");
            return 0;
        } else {
            print("\nSome tests FAILED\n");
            return 1;
        }
    }
}
