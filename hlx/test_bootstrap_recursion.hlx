// Test bootstrap compiler with recursion support
// This tests Phase 8a-8c: parser, semantic, lowering with #[max_depth(N)]

program test_bootstrap_recursion {

    // Test 1: Simple recursion with explicit max_depth
    #[max_depth(10)]
    fn countdown(n) {
        if (n <= 0) {
            return 0;
        }
        return 1 + countdown(n - 1);
    }

    // Test 2: Fibonacci with bounded recursion
    #[max_depth(20)]
    fn fib(n) {
        if (n <= 1) {
            return n;
        }
        return fib(n - 1) + fib(n - 2);
    }

    // Test 3: Default max_depth (no attribute)
    fn factorial(n) {
        if (n <= 1) {
            return 1;
        }
        return n * factorial(n - 1);
    }

    fn main() -> i64 {
        print("Testing Bootstrap Recursion Support\n");
        print("====================================\n\n");

        // Test 1
        print("Test 1: countdown(5) with max_depth(10)\n");
        let result1 = countdown(5);
        print("  Result: ");
        print(result1);
        print(" (expected 5)\n");

        // Test 2
        print("\nTest 2: fib(10) with max_depth(20)\n");
        let result2 = fib(10);
        print("  Result: ");
        print(result2);
        print(" (expected 55)\n");

        // Test 3
        print("\nTest 3: factorial(10) with default max_depth\n");
        let result3 = factorial(10);
        print("  Result: ");
        print(result3);
        print(" (non-zero)\n");

        print("\n✓ All bootstrap recursion tests completed!\n");

        return 1;
    }
}
