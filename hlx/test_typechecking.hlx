//! Test type checking - type mismatch detection

program test {
    // Case 1: Type mismatch in binary operation
    fn test_type_mismatch() {
        let x = 5;        // Int
        let y = "hello";  // String
        let z = x + y;    // ERROR: Cannot add Int and String
        return 0;
    }

    // Case 2: Wrong argument type to math function
    fn test_wrong_arg_type() {
        let x = 42;              // Int
        let result = sin(x);     // ERROR: sin expects Float, got Int
        return result;
    }

    // Case 3: Correct usage - Int to Float conversion
    fn test_correct_conversion() {
        let x = 42;
        let result = sin(to_float(x));  // OK: sin(Float)
        return result;
    }

    // Case 4: Float arithmetic (OK)
    fn test_float_arithmetic() {
        let x = 3.14;
        let y = 2.0;
        let sum = x + y;      // OK: Float + Float = Float
        let product = x * y;  // OK: Float * Float = Float
        return sum;
    }

    // Case 5: Int/Float compatibility
    fn test_int_float_compat() {
        let x = 5;       // Int
        let y = 3.14;    // Float
        let z = x + y;   // OK: Int + Float = Float (automatic promotion)
        return z;
    }

    // Case 6: Wrong number of arguments
    fn test_wrong_arg_count() {
        let result = sin(1.0, 2.0);  // ERROR: sin expects 1 arg, got 2
        return result;
    }

    // Case 7: Undefined variable
    fn test_undefined_var() {
        let result = undefined_var + 5;  // ERROR: undefined_var not declared
        return result;
    }

    // Case 8: String concatenation (OK)
    fn test_string_concat() {
        let greeting = "Hello";
        let name = "World";
        let message = greeting + name;  // OK: String + String = String
        print(message);
        return 0;
    }
}
